# Variables públicas (expuestas al cliente, con prefijo PUBLIC_)

# Plausible — dominio configurado en plausible.io.
# Si vacío, Plausible no se inyecta.
PUBLIC_PLAUSIBLE_DOMAIN=espacio1010.uy

# Google Tag Manager — container ID. La agencia inyecta GA4 / Meta Pixel desde acá.
# Si vacío, GTM no se inyecta.
PUBLIC_GTM_ID=
