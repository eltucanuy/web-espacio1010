# Variables públicas (expuestas al cliente, con prefijo PUBLIC_).
# Copiá este archivo a .env para desarrollo y configuralas en Vercel para producción.

# Supabase — guarda los leads del form de pre-registro de la home (tabla public.pre_registros).
# CRÍTICO: si faltan, el form falla en silencio (no guarda el lead).
# La anon/publishable key es segura para el cliente (RLS permite solo INSERT).
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google Tag Manager — container ID. La agencia inyecta GA4 / Meta Pixel desde GTM
# y los engancha al evento 'lead_preregistro' que dispara el form. Si vacío, no carga.
PUBLIC_GTM_ID=GTM-XXXXXXX

# Plausible — dominio configurado en plausible.io. Si vacío, no se inyecta.
PUBLIC_PLAUSIBLE_DOMAIN=espacio1010.uy
