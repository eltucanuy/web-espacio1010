---
/**
 * Conjunto de "enhancements" client-side que se cargan globalmente desde
 * BaseLayout. Todos opt-in via atributos data-*, todos respetan
 * prefers-reduced-motion, todos son progresivos (si JS falla, no se rompe nada).
 *
 * Incluye:
 *   - data-reveal:       IntersectionObserver para fade-up con stagger
 *   - data-counter:      Número que cuenta de 0 al final cuando entra viewport
 *   - data-magnetic:     Hover magnetic translation hacia el cursor
 *   - data-parallax:     Translate Y sutil basado en scroll (desktop only)
 *   - Lenis smooth scroll global (desktop only, fine pointer)
 */
---

<script>
  import Lenis from 'lenis';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  // ─── 1. Lenis smooth scroll (desktop only) ───────────────────────────
  // En mobile el scroll nativo es mejor (momentum del SO, mejor UX).
  let lenis: Lenis | null = null;
  if (isFinePointer && !prefersReducedMotion) {
    lenis = new Lenis({
      duration: 1.05,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // ease-out-expo
      smoothWheel: true,
      touchMultiplier: 1.5,
      wheelMultiplier: 1,
    });

    const raf = (time: number) => {
      lenis?.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  }

  // ─── 2. data-reveal: fade-up con stagger via IntersectionObserver ────
  // Elementos con [data-reveal] empiezan invisibles y animan al entrar viewport.
  // Si tienen padre con [data-reveal-group], los hijos animan en stagger.
  if (!prefersReducedMotion) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.revealDelay || '0', 10);
            setTimeout(() => el.classList.add('is-revealed'), delay);
            revealObserver.unobserve(el);
          }
        });
      },
      { rootMargin: '0px 0px -80px 0px', threshold: 0.05 }
    );

    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      revealObserver.observe(el);
    });

    // Stagger automático para hijos directos en grupos con [data-reveal-group]
    document.querySelectorAll<HTMLElement>('[data-reveal-group]').forEach((group) => {
      const baseDelay = parseInt(group.dataset.revealGroup || '80', 10);
      Array.from(group.children).forEach((child, i) => {
        const el = child as HTMLElement;
        if (!el.hasAttribute('data-reveal')) el.setAttribute('data-reveal', '');
        el.dataset.revealDelay = String(i * baseDelay);
        revealObserver.observe(el);
      });
    });
  } else {
    // Si reducimos movimiento, mostrar todo de inmediato.
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      el.classList.add('is-revealed');
    });
  }

  // ─── 3. data-counter: animar número del 0 al valor final ─────────────
  if (!prefersReducedMotion) {
    const counterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.counter || '0', 10);
            const duration = parseInt(el.dataset.counterDuration || '1400', 10);
            const start = performance.now();

            const tick = (now: number) => {
              const progress = Math.min((now - start) / duration, 1);
              // ease-out-quart
              const eased = 1 - Math.pow(1 - progress, 4);
              el.textContent = String(Math.floor(eased * target));
              if (progress < 1) requestAnimationFrame(tick);
              else el.textContent = String(target);
            };
            requestAnimationFrame(tick);
            counterObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    document.querySelectorAll<HTMLElement>('[data-counter]').forEach((el) => {
      counterObserver.observe(el);
    });
  }

  // ─── 4. data-magnetic: hover magnetic translate (desktop only) ───────
  if (isFinePointer && !prefersReducedMotion) {
    document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
      const strength = parseFloat(el.dataset.magnetic || '0.25');

      const onMove = (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
      };
      const onLeave = () => {
        el.style.transform = '';
      };

      el.addEventListener('mousemove', onMove);
      el.addEventListener('mouseleave', onLeave);
    });
  }

  // ─── 5. data-parallax: translate Y suave por scroll (desktop only) ───
  if (isFinePointer && !prefersReducedMotion) {
    const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');
    if (parallaxEls.length > 0) {
      const update = () => {
        parallaxEls.forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || '0.15');
          const rect = el.getBoundingClientRect();
          const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * -speed;
          el.style.transform = `translate3d(0, ${offset}px, 0)`;
        });
      };
      // Lenis emite "scroll", también escuchamos scroll nativo como fallback.
      if (lenis) {
        lenis.on('scroll', update);
      } else {
        window.addEventListener('scroll', update, { passive: true });
      }
      update();
    }
  }
</script>

<style is:global>
  /* ─── Reveal: estado inicial + animado ─── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s var(--ease-out-soft),
      transform 0.8s var(--ease-out-soft);
    will-change: opacity, transform;
  }

  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Variantes de reveal */
  [data-reveal="fade"] {
    transform: none;
  }

  [data-reveal="scale"] {
    transform: scale(0.96);
  }
  [data-reveal="scale"].is-revealed {
    transform: scale(1);
  }

  /* ─── Magnetic: transición suave para el reset ─── */
  [data-magnetic] {
    transition: transform 0.45s var(--ease-out-soft);
    will-change: transform;
  }

  /* ─── Parallax: GPU-accelerated ─── */
  [data-parallax] {
    will-change: transform;
  }

  /* ─── Respeta prefers-reduced-motion: sobreescribe todo ─── */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-magnetic],
    [data-parallax] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* ─── View Transitions: cross-fade suave entre páginas ─── */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.35s;
    animation-timing-function: var(--ease-out-soft);
  }

  /* ─── Glow en CTA primarios al hover (terracota suave) ─── */
  .btn-primary-glow {
    position: relative;
  }
  .btn-primary-glow::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: radial-gradient(circle at center, rgba(196, 117, 106, 0.45), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out-soft);
    pointer-events: none;
    z-index: -1;
  }
  .btn-primary-glow:hover::after {
    opacity: 1;
  }
</style>
