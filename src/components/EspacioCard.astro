---
import type { Espacio } from '../lib/site';

interface Props {
  espacio: Espacio;
  /** Si true, resalta la card (borde terracota). */
  featured?: boolean;
}

const { espacio, featured = false } = Astro.props;

const amuebladoLabel =
  espacio.amueblado === 'completo' ? 'Amueblado'
  : espacio.amueblado === 'versatil' ? 'Versátil'
  : 'Mixto';

const PRECIO_ARCOS = 700;
const precio = espacio.id === 'sala-subsuelo' ? PRECIO_ARCOS : 350;
---

<a
  href={`/los-espacios/${espacio.id}`}
  class={`group flex flex-col rounded-2xl border bg-white p-6 transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)] ${featured ? 'border-terracota/40' : 'border-hairline'}`}
>
  <div class="flex items-start justify-between gap-3">
    <span class="text-4xl font-bold leading-none text-terracota/20 transition-colors duration-500 group-hover:text-terracota/40">
      {espacio.metros}<span class="align-top text-base font-semibold">m²</span>
    </span>
    <span class="inline-flex items-center rounded-full border border-hairline bg-[#f8f9fa] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-soft">
      {amuebladoLabel}
    </span>
  </div>

  <h3 class="mt-5 text-lg text-ink">{espacio.nombre}</h3>
  <p class="mt-1.5 flex-1 text-sm leading-relaxed text-ink-soft">{espacio.resumen}</p>

  <div class="mt-5 flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
    <span>{espacio.capacidad} · <span class="font-semibold text-terracota">${precio}/h</span></span>
    <span class="inline-flex items-center gap-1 font-medium text-terracota transition-transform duration-300 group-hover:translate-x-0.5">
      Ver detalles
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>
