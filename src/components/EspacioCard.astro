---
import type { Espacio } from '../lib/site';

interface Props {
  espacio: Espacio;
  /** Si true, hace la card más alta para destacarla en grids */
  featured?: boolean;
}

const { espacio, featured = false } = Astro.props;

// Mientras no haya fotos reales: fondo decorativo terracota tinted con número del espacio.
// Cada card recibe una variación de tono según su id, así no se ve uniforme.
const accentByAmueblado = {
  completo: 'from-terracota-tint via-crema to-crema-warm',
  versatil: 'from-crema-warm via-crema to-terracota-tint/60',
  mixto: 'from-terracota-tint/70 via-crema to-crema-warm/80',
};

const gradient = accentByAmueblado[espacio.amueblado];
---

<a
  href={`/los-espacios/${espacio.id}`}
  class={`group relative flex flex-col overflow-hidden rounded-[var(--radius-lg)] border border-hairline bg-crema transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 hover:shadow-[var(--shadow-md)] hover:border-terracota/30 ${featured ? 'md:row-span-2' : ''}`}
>
  <!-- Visual placeholder hasta que haya fotos reales -->
  <div
    class={`relative aspect-[4/3] w-full overflow-hidden bg-gradient-to-br ${gradient} ${featured ? 'md:aspect-[4/5]' : ''}`}
  >
    <!-- Patrón decorativo sutil -->
    <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id={`p-${espacio.id}`} x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="1.2" fill="#1a1518" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill={`url(#p-${espacio.id})`} />
      </svg>
    </div>

    <!-- Número grande tipográfico como protagonista -->
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="font-display text-[7rem] leading-none text-terracota/25 transition-transform duration-700 ease-[var(--ease-out-soft)] group-hover:scale-110 group-hover:text-terracota/35">
        {espacio.metros}
        <span class="text-2xl align-top">m²</span>
      </span>
    </div>

    {
      espacio.destacado && (
        <span class="absolute left-4 top-4 inline-flex items-center rounded-full bg-ink px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-crema">
          Destacado
        </span>
      )
    }

    <span class="absolute right-4 top-4 inline-flex items-center rounded-full bg-crema/95 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-ink-soft">
      {
        espacio.amueblado === 'completo'
          ? 'Amueblado'
          : espacio.amueblado === 'versatil'
            ? 'Versátil'
            : 'Mixto'
      }
    </span>
  </div>

  <div class="flex flex-1 flex-col gap-3 p-6">
    <h3 class="font-display text-2xl text-ink">{espacio.nombre}</h3>
    <p class="text-sm leading-relaxed text-ink-soft">{espacio.resumen}</p>

    <div class="mt-auto flex items-center justify-between pt-4 text-xs text-ink-muted">
      <span>{espacio.capacidad}</span>
      <span class="inline-flex items-center gap-1 font-medium text-terracota transition-transform duration-300 group-hover:translate-x-0.5">
        Ver detalles
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>
  </div>
</a>
