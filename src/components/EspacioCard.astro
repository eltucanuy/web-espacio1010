---
import type { Espacio } from '../lib/site';
import { TIPO_LABEL } from '../lib/site';

interface Props {
  espacio: Espacio;
  /** Si true, resalta la card (borde terracota). */
  featured?: boolean;
}

const { espacio, featured = false } = Astro.props;
---

<a
  href={`/los-espacios/${espacio.id}`}
  class={`group flex flex-col overflow-hidden rounded-2xl border bg-white transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)] ${featured ? 'border-terracota/40' : 'border-hairline'}`}
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={espacio.fotos[0]}
      alt={`${espacio.nombre} de Espacio 1010`}
      width="1200"
      height="900"
      class="h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-out-soft)] group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <span class="absolute right-3 top-3 inline-flex items-center rounded-full bg-white/90 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-soft backdrop-blur">
      {TIPO_LABEL[espacio.tipo]}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-6">
  <h3 class="text-lg text-ink">{espacio.nombre}</h3>
  <p class="mt-1.5 flex-1 text-sm leading-relaxed text-ink-soft">{espacio.resumen}</p>

  <div class="mt-5 flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
    <span>{espacio.capacidadBreve} · {espacio.metros} m² · <span class="font-semibold text-terracota">${espacio.precioHora}/h</span></span>
    <span class="inline-flex items-center gap-1 font-medium text-terracota transition-transform duration-300 group-hover:translate-x-0.5">
      Ver detalles
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
  </div>
</a>
