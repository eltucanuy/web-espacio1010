---
/**
 * Floating WhatsApp button mobile-first.
 * Aparece después de scroll inicial (no en hero) y queda sticky bottom-right.
 * En desktop también aparece pero con menos protagonismo (es secundario al
 * CTA del nav). En mobile es el principal CTA always-visible.
 */
import { CONTACT } from '../lib/site';

const waLink = CONTACT.whatsappLink(
  'Hola, tengo una consulta sobre Espacio 1010.'
);
---

<a
  href={waLink}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Hablar por WhatsApp"
  data-floating-wa
  class="group fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white opacity-0 shadow-lg ring-4 ring-[#25D366]/20 transition-all duration-500 ease-[var(--ease-out-soft)] hover:scale-110 hover:bg-[#1ebe57] sm:bottom-7 sm:right-7"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.6 6.3A7.85 7.85 0 0012.05 4a7.94 7.94 0 00-6.78 12L4 20l4.1-1.07a7.93 7.93 0 003.95 1h.01c4.36 0 7.91-3.55 7.91-7.91 0-2.11-.82-4.1-2.37-5.72zm-5.55 12.16h-.01a6.58 6.58 0 01-3.36-.92l-.24-.14-2.43.64.65-2.37-.16-.25a6.55 6.55 0 01-1-3.5c0-3.63 2.95-6.58 6.58-6.58 1.76 0 3.4.68 4.64 1.93a6.55 6.55 0 011.93 4.65c0 3.62-2.96 6.54-6.6 6.54zm3.6-4.93c-.2-.1-1.17-.58-1.35-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.62.78-.12.13-.23.15-.43.05a5.41 5.41 0 01-1.59-.98 6 6 0 01-1.1-1.37c-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.06-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34l-.39-.01a.74.74 0 00-.54.25c-.18.2-.7.69-.7 1.67 0 .99.72 1.94.82 2.07.1.13 1.42 2.17 3.44 3.04.48.21.86.33 1.15.43.48.15.92.13 1.27.08.39-.06 1.17-.48 1.34-.94.16-.46.16-.86.12-.94-.06-.1-.18-.16-.39-.27z" />
  </svg>

  <!-- Tooltip / etiqueta hover (desktop only) -->
  <span class="pointer-events-none absolute right-full top-1/2 mr-3 hidden -translate-y-1/2 whitespace-nowrap rounded-full bg-ink px-4 py-2 text-xs font-medium text-crema opacity-0 transition-opacity duration-300 group-hover:opacity-100 sm:block">
    Chatear por WhatsApp
  </span>
</a>

<script>
  // Aparece sólo después del primer scroll significativo — no en el hero.
  const btn = document.querySelector<HTMLElement>('[data-floating-wa]');
  if (btn) {
    const update = () => {
      const visible = window.scrollY > 300;
      btn.style.opacity = visible ? '1' : '0';
      btn.style.pointerEvents = visible ? 'auto' : 'none';
      btn.style.transform = visible ? 'translateY(0)' : 'translateY(20px)';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
