---
/**
 * Carrusel de fotos con swipe nativo (scroll-snap), flechas en hover (desktop)
 * y puntitos. Mismo patrón que las cards de "Los espacios" de la home.
 *
 * Se auto-inicializa en `astro:page-load` (BaseLayout usa ClientRouter, así que
 * los listeners deben re-engancharse en cada navegación). El slot permite
 * superponer badges (ícono, etiqueta de tipo, etc.).
 */
interface Props {
  fotos: readonly string[];
  /** Base del alt: se le agrega "— foto N". */
  alt: string;
  class?: string;
}

const { fotos, alt, class: className = '' } = Astro.props;
---

<div class={`group relative overflow-hidden ${className}`} data-carousel>
  <div
    class="flex h-full w-full snap-x snap-mandatory overflow-x-auto scroll-smooth [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    data-track
  >
    {
      fotos.map((src, i) => (
        <div class="h-full w-full flex-shrink-0 snap-center">
          <img
            src={src}
            alt={`${alt} — foto ${i + 1}`}
            width="1200"
            height="900"
            class="h-full w-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))
    }
  </div>

  <slot />

  {
    fotos.length > 1 && (
      <>
        <button
          type="button"
          data-prev
          aria-label="Foto anterior"
          class="absolute left-2 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-ink shadow-[var(--shadow-sm)] backdrop-blur transition hover:bg-white group-hover:flex"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button
          type="button"
          data-next
          aria-label="Foto siguiente"
          class="absolute right-2 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-ink shadow-[var(--shadow-sm)] backdrop-blur transition hover:bg-white group-hover:flex"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div class="absolute bottom-3 left-1/2 z-10 flex -translate-x-1/2 gap-1.5" data-dots>
          {fotos.map((_, i) => (
            <span
              data-dot
              class={`h-1.5 rounded-full bg-white shadow transition-all duration-300 ${i === 0 ? 'w-4 opacity-100' : 'w-1.5 opacity-60'}`}
            />
          ))}
        </div>
      </>
    )
  }
</div>

<script>
  // data-ready evita doble binding si astro:page-load re-dispara sobre el mismo DOM.
  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((car) => {
      if (car.dataset.ready) return;
      car.dataset.ready = '1';
      const track = car.querySelector<HTMLElement>('[data-track]');
      if (!track) return;
      const dots = Array.from(car.querySelectorAll<HTMLElement>('[data-dot]'));
      const slideWidth = () => track.clientWidth;

      const syncDots = () => {
        const i = Math.round(track.scrollLeft / slideWidth());
        dots.forEach((d, j) => {
          d.classList.toggle('w-4', j === i);
          d.classList.toggle('opacity-100', j === i);
          d.classList.toggle('w-1.5', j !== i);
          d.classList.toggle('opacity-60', j !== i);
        });
      };

      let raf = 0;
      track.addEventListener(
        'scroll',
        () => {
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(syncDots);
        },
        { passive: true }
      );

      const go = (dir: number) => {
        const i = Math.round(track.scrollLeft / slideWidth());
        const next = Math.max(0, Math.min(dots.length - 1, i + dir));
        track.scrollTo({ left: next * slideWidth(), behavior: 'smooth' });
      };
      car.querySelector('[data-prev]')?.addEventListener('click', () => go(-1));
      car.querySelector('[data-next]')?.addEventListener('click', () => go(1));
      dots.forEach((d, j) =>
        d.addEventListener('click', () => track.scrollTo({ left: j * slideWidth(), behavior: 'smooth' }))
      );
    });
  };
  document.addEventListener('astro:page-load', init);
  init();
</script>
