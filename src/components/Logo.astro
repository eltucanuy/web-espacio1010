---
/**
 * Logo "ESPACIO 1010" — usa los SVG reales de marca de /public:
 *   - dark  → /logo.svg (trazo oscuro, para fondos claros: nav)
 *   - light → /wordmark-light.svg (trazo claro, para fondos oscuros: footer)
 * Reemplaza al placeholder tipográfico original (2026-07-05, pedido de Rafa).
 */
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}

const { variant = 'dark', class: className = '' } = Astro.props;

const src = variant === 'light' ? '/wordmark-light.svg' : '/logo.svg';
---

<a href="/" class={`inline-flex items-center ${className}`} aria-label="Espacio 1010 — inicio">
  <img src={src} alt="Espacio 1010" width="907" height="344" class="h-9 w-auto sm:h-10" />
</a>
