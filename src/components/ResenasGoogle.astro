---
/**
 * ResenasGoogle — banda oscura con las reseñas de Google: rating EN VIVO +
 * carrusel continuo. ÚNICO lugar a tocar para todo lo de reseñas (decisión
 * Rafa 2026-07-05): lo usan la home y las 10 landings /para/.
 *
 * - Promedio y cantidad se actualizan en vivo desde /api/resenas (Places API,
 *   ver api/resenas.js); RATING de abajo es el respaldo si la API no responde.
 * - Los TEXTOS se curan a mano acá (la API solo devuelve 5 reseñas a elección
 *   de Google). Verbatim salvo tipografía; sin la reseña del propio Rafael.
 *   Para refrescar: abrir ADDRESS.mapsUrl y actualizar el array.
 * - Carrusel: mismo patrón que emotiva.com.uy (transform por JS + drag).
 *   Compatible con view transitions (se re-inicializa en astro:page-load).
 */
import Container from './Container.astro';
import { ADDRESS } from '../lib/site';

const RATING = { promedio: '5,0', cantidad: 7 }; // respaldo (snapshot 2026-07-05)

const resenas = [
  {
    texto: 'Un precioso espacio, que fusiona calidez, practicidad y funcionalidad. Está totalmente renovado y ofrece posibilidades los 7 días de la semana. A mi modo de ver, una excelente elección que ya estoy tomando.',
    nombre: 'Patricia S',
  },
  {
    texto: 'Tuve el privilegio de dictar un curso de Flores de Bach de 4 días en el Espacio. Fue una experiencia muy disfrutable ya que el lugar, cálido y luminoso, te hace sentir como en casa: cómodo, suelto y libre. Las alumnas encantadas con el lugar…',
    nombre: 'Gastón Laffitte',
  },
  {
    texto: 'Un lugar hermoso para trabajar tanto de forma individual como grupal. Un hermoso clima. Muy prolijo todo. Recomiendo.',
    nombre: 'María Rosa Baztarrica',
  },
  {
    texto: 'Espectacular! Un lugar super cómodo para trabajar, fácil de gestionar y organizar tu trabajo! Recomiendo!',
    nombre: 'Agus Lima Vila',
  },
  {
    texto: 'Hermoso lugar! Re luminoso y súper práctico para alquilar',
    nombre: 'Vanessa Zunino',
  },
  {
    texto: 'Lindos consultorios y muy práctico!',
    nombre: 'Martin Cassella',
  },
];

const STAR = 'M12 2l2.9 6.26 6.6.72-4.9 4.55 1.34 6.47L12 16.77 6.06 20l1.34-6.47L2.5 8.98l6.6-.72L12 2z';
---

<section class="bg-ink py-16 text-white sm:py-24">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota-light">Reseñas de Google</p>
      <h2 class="text-3xl text-white sm:text-4xl"><span data-g-rating>{RATING.promedio}</span> de 5 en Google.</h2>
      <div class="mt-4 flex items-center justify-center gap-1" aria-label={`Calificación ${RATING.promedio} de 5 estrellas`}>
        {[1, 2, 3, 4, 5].map(() => (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="#FBBC04" aria-hidden="true"><path d={STAR}/></svg>
        ))}
      </div>
      <p class="mt-3 text-sm text-white/55">Según <span data-g-count>{RATING.cantidad}</span> reseñas públicas en nuestro perfil de Google</p>
      <p class="mt-4 text-lg leading-relaxed text-white/70 text-pretty">Lo que dicen los profesionales que ya trabajan acá.</p>
    </div>
  </Container>

  <!-- Carrusel continuo: auto-avance suave, pausa en hover y drag/swipe manual. -->
  <div data-resenas-marquee class="marquee mt-12" aria-label="Reseñas verificadas de Google" role="region">
    <div class="marquee-track py-2">
      {
        [...resenas, ...resenas].map((r, i) => (
          <figure
            aria-hidden={i >= resenas.length ? 'true' : undefined}
            class="flex w-80 flex-col rounded-2xl border border-white/10 bg-white/[0.04] p-6"
          >
            <div class="mb-3 flex gap-0.5" aria-label="5 de 5 estrellas">
              {[1, 2, 3, 4, 5].map(() => (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="#FBBC04" aria-hidden="true"><path d={STAR}/></svg>
              ))}
            </div>
            <blockquote class="flex-1 text-sm leading-relaxed text-white/85 text-pretty">{r.texto}</blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-terracota/25 text-sm font-semibold text-terracota-light">{r.nombre.charAt(0)}</span>
              <div>
                <p class="text-sm font-semibold text-white">{r.nombre}</p>
                <p class="text-xs text-white/55">Reseña en Google</p>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>

  <Container>
    <div class="mt-10 text-center">
      <a
        href={ADDRESS.mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-11 items-center justify-center gap-2 rounded-full border border-white/20 px-6 text-sm font-semibold text-white/85 transition-all duration-300 hover:border-white/40 hover:text-white"
      >
        Ver todas las reseñas en Google
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </Container>
</section>

<script>
  // Rating en vivo + carrusel. Con view transitions (ClientRouter) el módulo
  // corre UNA vez por visita: la inicialización se re-engancha en cada
  // astro:page-load y el loop de animación lee las referencias vigentes.
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const PX_PER_SEC = 45;

  let marquee: HTMLElement | null = null;
  let track: HTMLElement | null = null;
  let x = 0;
  let halfWidth = 0;
  let isHovering = false;
  let isDragging = false;
  let dragStartClientX = 0;
  let xAtDragStart = 0;
  let lastTimestamp = 0;
  let visible = false;
  let loopStarted = false;

  const wrapX = () => { if (halfWidth > 0) x = ((x % halfWidth) + halfWidth) % halfWidth; };
  const applyX = () => { if (track) track.style.transform = `translate3d(${-x}px, 0, 0)`; };

  const tick = (ts: number) => {
    if (!lastTimestamp) lastTimestamp = ts;
    const dt = ts - lastTimestamp;
    lastTimestamp = ts;
    if (track && !isDragging && !isHovering && visible) {
      x += (PX_PER_SEC * dt) / 1000;
      wrapX();
      applyX();
    }
    requestAnimationFrame(tick);
  };

  const actualizarRating = () => {
    fetch('/api/resenas')
      .then((r) => (r.ok ? r.json() : null))
      .then((d) => {
        if (!d || !d.rating) return;
        document.querySelectorAll('[data-g-rating]').forEach((el) => { el.textContent = d.rating; });
        if (d.cantidad) document.querySelectorAll('[data-g-count]').forEach((el) => { el.textContent = String(d.cantidad); });
      })
      .catch(() => {});
  };

  const init = () => {
    actualizarRating();

    marquee = document.querySelector<HTMLElement>('[data-resenas-marquee]');
    track = marquee?.querySelector<HTMLElement>('.marquee-track') ?? null;
    if (!marquee || !track || marquee.dataset.bound) return;
    marquee.dataset.bound = '1';

    x = 0;
    halfWidth = track.scrollWidth / 2;
    isHovering = false;
    isDragging = false;
    visible = false;

    marquee.addEventListener('mouseenter', () => { isHovering = true; });
    marquee.addEventListener('mouseleave', () => { isHovering = false; });

    marquee.addEventListener('pointerdown', (e) => {
      isDragging = true;
      dragStartClientX = e.clientX;
      xAtDragStart = x;
      try { marquee!.setPointerCapture(e.pointerId); } catch {}
    });
    marquee.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      x = xAtDragStart - (e.clientX - dragStartClientX);
      wrapX();
      applyX();
    });
    const endDrag = (e: PointerEvent) => {
      if (!isDragging) return;
      isDragging = false;
      try { marquee!.releasePointerCapture(e.pointerId); } catch {}
    };
    marquee.addEventListener('pointerup', endDrag);
    marquee.addEventListener('pointercancel', endDrag);
    marquee.addEventListener('pointerleave', endDrag);

    new IntersectionObserver(
      ([entry]) => { visible = entry.isIntersecting; },
      { threshold: 0.05 }
    ).observe(marquee);

    window.addEventListener('resize', () => { if (track) halfWidth = track.scrollWidth / 2; });

    if (!loopStarted && !reducedMotion) {
      loopStarted = true;
      requestAnimationFrame(tick);
    }
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
