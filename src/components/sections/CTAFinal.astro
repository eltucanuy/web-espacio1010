---
import Container from '../Container.astro';
import Button from '../Button.astro';
import { SITE, CONTACT } from '../../lib/site';
---

<section class="py-24 sm:py-32">
  <Container>
    <div class="relative overflow-hidden rounded-[var(--radius-xl)] bg-gradient-to-br from-terracota via-terracota-dark to-ink p-12 text-center sm:p-20">
      <div class="absolute inset-0 opacity-10" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="cta-pattern" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
              <circle cx="25" cy="25" r="1" fill="white" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#cta-pattern)" />
        </svg>
      </div>

      <div class="relative mx-auto max-w-2xl">
        <h2 class="text-balance text-crema">
          Tu próxima sesión
          <span class="italic">empieza acá</span>.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-crema/85">
          Registrate gratis, mirá la disponibilidad real y reservá la primera
          hora cuando quieras. Si tenés dudas, te respondemos por WhatsApp.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href={SITE.agendaUrl} variant="primary" size="lg" class="bg-crema text-terracota hover:bg-white hover:text-terracota-dark">
            Crear mi cuenta gratis
          </Button>
          <Button
            href={CONTACT.whatsappLink('Hola, tengo una consulta sobre Espacio 1010.')}
            variant="ghost"
            size="lg"
            class="text-crema hover:bg-crema/10"
            target="_blank"
          >
            Hablar por WhatsApp
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
