---
import Container from '../Container.astro';
import Button from '../Button.astro';
import { SITE, ADDRESS } from '../../lib/site';
---

<section class="relative overflow-hidden pt-12 pb-20 sm:pt-16 sm:pb-28 md:pt-24 md:pb-36">
  <!-- Capa decorativa de fondo: gradiente sutil + grano + acentos terracota -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-crema via-crema-warm/40 to-terracota-tint/30"></div>

    <!-- Forma orgánica terracota grande, derecha -->
    <div
      class="absolute -right-40 top-20 h-[500px] w-[500px] rounded-full opacity-40 blur-3xl"
      style="background: radial-gradient(circle, #c4756a 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Forma orgánica gris suave, abajo izquierda -->
    <div
      class="absolute -left-32 bottom-0 h-[400px] w-[400px] rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(circle, #565153 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Grano sutil para textura editorial -->
    <svg class="absolute inset-0 h-full w-full opacity-[0.04]" aria-hidden="true">
      <filter id="grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="3" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grain)" />
    </svg>
  </div>

  <Container size="wide">
    <div class="grid gap-12 md:grid-cols-12 md:items-center">
      <div class="md:col-span-7 lg:col-span-7">
        <p data-reveal data-reveal-delay="0" class="mb-6 inline-flex items-center gap-2 rounded-full border border-terracota/20 bg-crema/80 px-4 py-2 text-xs font-medium text-terracota backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-terracota opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-terracota"></span>
          </span>
          Próximamente abrimos en {ADDRESS.neighborhood}
        </p>

        <h1 data-reveal data-reveal-delay="100" class="text-balance text-ink">
          Tu consultorio,
          <span class="italic text-terracota">sin complicaciones</span>.
        </h1>

        <p data-reveal data-reveal-delay="200" class="mt-7 max-w-xl text-lg leading-relaxed text-ink-soft text-pretty md:text-xl">
          12 espacios boutique para profesionales de la salud y el bienestar.
          Reservás online, entrás cuando querés, atendés con todo a punto.
          Edificio centenario reciclado a nuevo, en pleno {ADDRESS.neighborhood}.
        </p>

        <div data-reveal data-reveal-delay="300" class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <Button href={SITE.agendaUrl} variant="primary" size="lg" class="btn-primary-glow">
            Reservá tu primera hora
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </Button>
          <Button href="/los-espacios" variant="ghost" size="lg">
            Conocé los espacios
          </Button>
        </div>

        <div data-reveal data-reveal-delay="400" class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-ink-muted">
          <span class="inline-flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 6v6l4 2" stroke-linecap="round" />
            </svg>
            Acceso 24/7
          </span>
          <span class="inline-flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
              <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="12" cy="12" r="10" />
            </svg>
            Cancelás con 24h, no pagás
          </span>
          <span class="inline-flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke-linejoin="round" />
            </svg>
            Cowork incluido
          </span>
        </div>
      </div>

      <!-- Visual principal (placeholder editorial hasta tener fotos) -->
      <div class="md:col-span-5 lg:col-span-5">
        <div data-reveal="scale" data-reveal-delay="400" class="relative">
          <!-- Card visual principal con parallax sutil al scroll -->
          <div data-parallax="0.06" class="relative aspect-[4/5] overflow-hidden rounded-[var(--radius-xl)] bg-gradient-to-br from-terracota via-terracota-dark to-ink shadow-[var(--shadow-hero)]">
            <!-- Patrón geométrico sutil -->
            <div class="absolute inset-0 opacity-20" aria-hidden="true">
              <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <pattern id="hero-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
                    <circle cx="30" cy="30" r="1" fill="white" />
                  </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#hero-pattern)" />
              </svg>
            </div>

            <!-- Número 1010 grande como protagonista -->
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display text-[12rem] leading-none text-crema/15 select-none">
                1010
              </span>
            </div>

            <!-- Cita editorial -->
            <div class="absolute inset-0 flex flex-col justify-end p-10">
              <p class="font-display text-2xl leading-tight text-crema">
                "Un lugar donde el diseño eleva la práctica profesional."
              </p>
              <div class="mt-4 h-px w-12 bg-crema/40"></div>
              <p class="mt-3 text-xs uppercase tracking-[0.18em] text-crema/70">
                Espacio 1010 · Cordón
              </p>
            </div>
          </div>

          <!-- Card flotante: testimonio rápido (placeholder) -->
          <div class="absolute -bottom-6 -left-4 hidden max-w-xs rounded-2xl border border-hairline bg-crema/95 p-5 shadow-[var(--shadow-md)] backdrop-blur-sm md:block">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-gradient-to-br from-terracota to-terracota-dark"></div>
              <div>
                <p class="text-xs font-semibold text-ink">Profesional fundadora</p>
                <p class="text-[11px] text-ink-muted">Psicóloga, Cordón</p>
              </div>
            </div>
            <p class="mt-3 text-sm leading-snug text-ink-soft">
              "Reservar acá me sacó horas de logística por semana. Es otra forma de trabajar."
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
