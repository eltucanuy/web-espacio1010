---
import Container from '../Container.astro';
import SectionHeader from '../SectionHeader.astro';
import { NICHOS } from '../../lib/site';

// Subset jerarquizado: psi clínico al frente, bienestar después. Decisión deliberada
// para no diluir el posicionamiento de la audiencia core.
const profesionales = [
  { ...NICHOS.find((n) => n.slug === 'psicologos')!, descripcion: 'Sesiones individuales o de pareja, divan opcional.' },
  { ...NICHOS.find((n) => n.slug === 'psiquiatras')!, descripcion: 'Consulta clínica con privacidad acústica garantizada.' },
  { ...NICHOS.find((n) => n.slug === 'psicopedagogos')!, descripcion: 'Espacios con materiales y zona de juego para niños.' },
  { ...NICHOS.find((n) => n.slug === 'nutricionistas')!, descripcion: 'Mobiliario sobrio, escritorio y privacidad.' },
  { ...NICHOS.find((n) => n.slug === 'meditacion-yoga')!, descripcion: 'Salones versátiles con colchonetas y luz regulable.' },
  { ...NICHOS.find((n) => n.slug === 'talleres-grupos')!, descripcion: 'Sala subsuelo para hasta 30 personas, sin columnas.' },
];
---

<section class="py-24 sm:py-32 bg-crema-warm/30">
  <Container>
    <SectionHeader
      eyebrow="Para vos"
      title="Diseñado para distintas formas de cuidar."
      subtitle="Cada espacio se adapta a tu disciplina. Si no ves la tuya, escribinos: el edificio fue pensado para alojar muchas formas del bienestar."
    />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        profesionales.map((p) => (
          <a
            href={`/para/${p.slug}`}
            class="group relative flex items-start gap-5 rounded-[var(--radius-lg)] border border-hairline bg-crema p-6 transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]"
          >
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-terracota-tint text-terracota transition-colors group-hover:bg-terracota group-hover:text-crema">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 2.5a4 4 0 014 4v3a4 4 0 11-8 0v-3a4 4 0 014-4z" />
                <path d="M5 21v-1a7 7 0 0114 0v1" stroke-linecap="round" />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-display text-xl text-ink">{p.label}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{p.descripcion}</p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-terracota transition-transform duration-300 group-hover:translate-x-0.5">
                Ver más
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </Container>
</section>
