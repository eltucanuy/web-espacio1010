---
import Container from '../Container.astro';
import SectionHeader from '../SectionHeader.astro';
import Quiz from '../Quiz.tsx';
import { SITE } from '../../lib/site';
---

<section class="py-24 sm:py-32">
  <Container size="narrow">
    <SectionHeader
      eyebrow="Te ayudamos a elegir"
      title="¿No sabés cuál es para vos?"
      subtitle="Contestá tres preguntas rápidas y te recomendamos el espacio que mejor se ajusta a tu práctica."
    />

    <div class="mt-12">
      <Quiz client:visible agendaUrl={SITE.agendaUrl} />
    </div>
  </Container>
</section>
