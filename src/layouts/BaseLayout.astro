---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import Enhancements from '../components/Enhancements.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import { SITE } from '../lib/site';
import { localBusinessSchema } from '../lib/schema';

interface Props {
  title?: string;
  description?: string;
  /** Imagen OG explícita (URL absoluta o ruta en /public) */
  image?: string;
  /** Slug para usar la OG generada dinámica: /og/<slug>.png (ver src/pages/og/[slug].png.ts) */
  ogSlug?: string;
  /** Si la página es noindex (ej: landings de campañas pagas) */
  noindex?: boolean;
  /** Si querés override del canonical (raro) */
  canonical?: string;
}

const {
  title,
  description = SITE.description,
  image,
  ogSlug,
  noindex = false,
  canonical,
} = Astro.props;

// Prioridad: image explícita > ogSlug generado > fallback SVG.
const resolvedImage = image ?? (ogSlug ? `/og/${ogSlug}.png` : '/og-default.svg');

const fullTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const imageUrl = resolvedImage.startsWith('http')
  ? resolvedImage
  : new URL(resolvedImage, SITE.url).toString();

// Schema.org LocalBusiness — refinado con horarios duales y datos completos.
const schemaBusiness = localBusinessSchema(imageUrl);
---

<!doctype html>
<html lang="es-UY">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_UY" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Color de marca para chrome móvil -->
    <meta name="theme-color" content="#9e4e42" />

    <!-- Favicons — set de marca compartido con la app (verificado idéntico 2026-06-11) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fuentes — Inter self-host vía @fontsource (importado en el frontmatter).
         Sin dependencia de Google Fonts: mejor privacidad y performance. -->

    <!-- Schema.org -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBusiness)} />

    <!-- Analytics: Plausible + GTM stub (sólo en prod, env-driven) -->
    <Analytics />

    <!-- Slot para metadata extra por página (ej: schema.org Service / FAQPage / Product) -->
    <slot name="head" />

    <!-- View Transitions API — navegación entre páginas tipo app (Astro nativo). -->
    <ClientRouter />
  </head>

  <body class="min-h-dvh flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:rounded focus:bg-terracota focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido
    </a>

    <Nav />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <!-- Floating WhatsApp aparece después de scroll inicial -->
    <FloatingWhatsApp />

    <!-- Animations + scroll + magnetic hover (vanilla, opt-in via data-*) -->
    <Enhancements />
  </body>
</html>
