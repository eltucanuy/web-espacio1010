---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { SITE } from '../lib/site';

const pasos = [
  {
    n: '01',
    titulo: 'Te registrás',
    bajada: 'En 30 segundos. Email, profesión, datos básicos.',
    detalle:
      'Tu cuenta queda en revisión y la aprobamos el mismo día — siempre por una persona, no un bot. Eso nos permite cuidar quién entra al edificio y que la comunidad de profesionales se mantenga curada.',
    bullets: [
      'Validamos cédula y matrícula profesional cuando aplica',
      'Te contactamos si necesitamos algún dato adicional',
      'Apenas aprobamos, recibís el código de acceso por mail',
    ],
  },
  {
    n: '02',
    titulo: 'Buscás disponibilidad',
    bajada: 'Ves los 12 espacios con sus horarios libres en tiempo real.',
    detalle:
      'La agenda muestra exactamente lo que está libre cuando vos entrás. Filtrás por día, por tamaño de espacio o por tipo de equipamiento. Si querés algo recurrente, podés bloquear un mismo día y hora de la semana.',
    bullets: [
      'Reserva eventual: hora suelta cuando la necesitás',
      'Reserva fija: día y hora garantizados todas las semanas',
      'Filtros por capacidad, mobiliario y profesional',
    ],
  },
  {
    n: '03',
    titulo: 'Reservás en un click',
    bajada: 'Confirmás y listo. Cero idas y vueltas con humanos.',
    detalle:
      'No hay aprobación intermedia, no hay "te confirmo mañana". Apenas hacés click la reserva queda firme y aparece en tu panel. $350 la hora en todos los consultorios; $700 la hora la Sala Arcos del subsuelo. Si cambian tus planes, cancelar una eventual con 24 horas no tiene costo.',
    bullets: [
      'Confirmación inmediata por mail',
      'Aparece en tu panel y en tu calendario',
      '$350/h consultorios · $700/h Sala Arcos',
    ],
  },
  {
    n: '04',
    titulo: 'Entrás cuando querés',
    bajada: '24/7, con tu código personal. Sin coordinar con nadie.',
    detalle:
      'Tu código abre la puerta de calle y el espacio que reservaste. Llegás antes, esperás en la sala de cowork sin pagar extra. Tus pacientes esperan en la sala de espera común, cómoda y con privacidad.',
    bullets: [
      'Código personal que cambia con cada reserva',
      'Sala de cowork gratis mientras esperás',
      'Tu paciente espera en una sala pensada para eso',
    ],
  },
];

const schemaHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo reservar consultorio en Espacio 1010',
  description:
    'Pasos para registrarte, buscar disponibilidad, reservar y acceder a tu espacio en Espacio 1010.',
  step: pasos.map((p, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: p.titulo,
    text: p.detalle,
  })),
};
---

<BaseLayout
  title="Cómo funciona"
  description="Cómo reservar consultorio en Espacio 1010 en 4 pasos: registrate, buscá disponibilidad real, reservá online y entrá 24/7 con tu código personal."
  ogSlug="como-funciona"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaHowTo)} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-white pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Cómo funciona
      </p>
      <h1 class="text-balance">
        Cuatro pasos.
        <span class="text-terracota">El resto es atender.</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        Construimos Espacio 1010 con la convicción de que la tecnología tiene
        que desaparecer. Vos no tendrías que pelearte con planillas, mensajes
        o llamados para conseguir un lugar donde trabajar. Acá es así.
      </p>
    </Container>
  </section>

  <!-- Pasos en detalle -->
  <section class="bg-white pb-20 sm:pb-24">
    <Container>
      <ol class="space-y-4">
        {
          pasos.map((p) => (
            <li class="overflow-hidden rounded-[var(--radius-lg)] border border-hairline bg-[#f8f9fa] transition-all duration-500 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
              <div class="grid gap-10 p-8 md:grid-cols-12 md:p-12">
                <div class="md:col-span-4">
                  <span class="text-7xl font-bold leading-none text-terracota/20">{p.n}</span>
                  <h2 class="mt-4 text-2xl text-ink sm:text-3xl">{p.titulo}</h2>
                  <p class="mt-3 text-base text-ink-soft">{p.bajada}</p>
                </div>
                <div class="md:col-span-8">
                  <p class="text-lg leading-relaxed text-ink-soft text-pretty">{p.detalle}</p>
                  <ul class="mt-6 space-y-2.5">
                    {p.bullets.map((b) => (
                      <li class="flex items-start gap-3 text-base text-ink">
                        <svg class="mt-1 flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                          <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        {b}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </Container>
  </section>

  <!-- Política de cancelación destacada (diferencial fuerte) -->
  <section class="bg-[#f8f9fa] py-16 sm:py-24">
    <Container size="narrow">
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Política de cancelaciones
      </p>
      <h2 class="text-3xl text-ink sm:text-4xl">
        La más favorable del mercado.
      </h2>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-soft text-pretty">
        Pensada para que la flexibilidad que vos das a tus pacientes la tengas
        también con nosotros. Sin letra chica.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
          </span>
          <h3 class="mt-5 text-lg text-ink">Reservas fijas</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            Podés cancelar <strong class="text-ink">1 de cada 5</strong> reservas
            de tu serie fija sin ningún cargo. Así mantenemos la equidad con
            quienes esperan ese mismo slot.
          </p>
        </div>

        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <h3 class="mt-5 text-lg text-ink">Eventuales con 24 h</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            Si avisás con <strong class="text-ink">24 horas o más</strong> de
            anticipación, la reserva se libera <strong class="text-ink">sin
            costo</strong>. Cero penalización.
          </p>
        </div>

        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
          </span>
          <h3 class="mt-5 text-lg text-ink">Dentro de las 24 h</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">
            Si cancelás con menos de 24 horas, te
            <strong class="text-ink">bonificamos el 50%</strong>: pagás solo la
            mitad de esa hora.
          </p>
        </div>
      </div>

      <p class="mt-8 text-sm text-ink-muted">
        Resumen: 1 de cada 5 fijas sin cargo · eventuales con 24 h sin cargo ·
        dentro de las 24 h, 50% bonificado. Todo el detalle queda visible en tu
        panel al momento de cancelar.
      </p>
    </Container>
  </section>

  <!-- FAQ rápida -->
  <section class="bg-white py-16 sm:py-24">
    <Container size="narrow">
      <h2 class="text-3xl text-ink sm:text-4xl">Preguntas que nos hacen seguido.</h2>

      <div class="mt-10 space-y-4">
        {[
          {
            q: '¿Puedo probar el espacio antes de reservar?',
            a: 'Sí. Coordinamos visita guiada sin compromiso por WhatsApp. Te mostramos los 12 espacios y respondemos cualquier duda.',
          },
          {
            q: '¿Tengo que firmar contrato anual?',
            a: 'No. Reservás por hora, las veces que quieras, sin contrato. Las series fijas son mes a mes — si querés cortar, lo hacés desde tu panel.',
          },
          {
            q: '¿Cuánto cuesta la hora?',
            a: '$350 la hora en todos los consultorios. La Sala Arcos, la gran sala del subsuelo para grupos y talleres, sale $700 la hora. Sin costos de gestión escondidos.',
          },
          {
            q: '¿Cómo accede mi paciente?',
            a: 'Te avisa por timbre o le abrís remoto desde la app. Pasa a la sala de espera común y vos lo recibís cuando estás listo.',
          },
          {
            q: '¿Qué pasa si llego tarde?',
            a: 'Tu código sigue funcionando — la reserva es tuya hasta que se cumpla la hora completa. Si necesitás extender, depende de la disponibilidad del siguiente turno.',
          },
          {
            q: '¿Puedo dejar materiales en el espacio?',
            a: 'En los espacios versátiles no, son compartidos. En estudios y consultas amobladas hay opción de pack mensual con armario reservado — preguntá por WhatsApp.',
          },
        ].map((item) => (
          <details class="group rounded-2xl border border-hairline bg-[#f8f9fa] p-6 transition-all duration-300 hover:border-terracota/30">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-medium text-ink">
              {item.q}
              <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-terracota-tint text-terracota transition-transform duration-300 group-open:rotate-45">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M12 5v14M5 12h14" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <p class="mt-4 text-base leading-relaxed text-ink-soft">{item.a}</p>
          </details>
        ))}
      </div>

      <div class="mt-10 text-center">
        <Button href="/preguntas-frecuentes" variant="ghost" size="md">
          Ver todas las preguntas
        </Button>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20 sm:py-28">
    <Container>
      <div class="rounded-[var(--radius-xl)] bg-terracota p-12 text-center text-white sm:p-20">
        <h2 class="text-balance text-white">¿Probamos?</h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/85">
          Crear tu cuenta es gratis y toma 30 segundos. Después ves la
          disponibilidad real y reservás cuando quieras.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href={SITE.agendaUrl} variant="primary" size="lg" class="bg-white text-terracota hover:bg-white/90">
            Crear mi cuenta
          </Button>
          <Button href="/precios" variant="ghost" size="lg" class="text-white hover:bg-white/10">
            Ver precios
          </Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
