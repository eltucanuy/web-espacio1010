---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import ContactForm from '../components/ContactForm.tsx';
import { SITE, CONTACT, ADDRESS, SOCIAL } from '../lib/site';

// Número WhatsApp para el form — sin "+", para wa.me
const waNumber = CONTACT.whatsappLeads.replace(/[^0-9]/g, '');

const schemaContactPage = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto — Espacio 1010',
  url: `${SITE.url}/contacto`,
  about: { '@id': `${SITE.url}/#business` },
};
---

<BaseLayout
  title="Contacto — consultorios por hora en Montevideo"
  description="Contactá a Espacio 1010, consultorios por hora en Parque Rodó, Montevideo: coordiná una visita, resolvé dudas o pedí info de precios y disponibilidad por WhatsApp."
  ogSlug="contacto"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaContactPage)} />
  </Fragment>
  <section class="pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Contacto
      </p>
      <h1 class="text-balance">
        Hablamos
        <span class="text-terracota">cuando querés</span>.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        WhatsApp es nuestro canal principal — somos un equipo chico y te
        respondemos en cuanto podemos. Si preferís mail, también va. La visita
        se coordina sin compromiso.
      </p>
    </Container>
  </section>

  <section class="pb-24">
    <Container>
      <div class="grid gap-12 md:grid-cols-12">
        <!-- Form -->
        <div class="md:col-span-7">
          <div class="rounded-2xl border border-hairline bg-white p-8 shadow-[var(--shadow-md)] sm:p-10">
            <h2 class="font-display text-2xl text-ink">Escribinos</h2>
            <p class="mt-2 text-sm text-ink-soft">
              Completá esto y abrimos WhatsApp con el mensaje listo. Tardás 20 segundos.
            </p>

            <div class="mt-8">
              <ContactForm client:load whatsappNumber={waNumber} />
            </div>
          </div>
        </div>

        <!-- Otros canales -->
        <aside class="md:col-span-5">
          <div class="sticky top-24 space-y-6">
            <div class="rounded-2xl border border-terracota/30 bg-terracota/[0.06] p-7">
              <h3 class="font-display text-xl text-ink">¿Todavía no te registraste?</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">
                Es gratis, sin tarjeta y sin compromiso: te guardamos tu primera hora
                gratis para usarla cuando quieras.
              </p>
              <a
                href="/#registro"
                class="mt-5 inline-flex h-11 items-center justify-center gap-2 rounded-full bg-terracota px-6 text-sm font-medium text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-terracota-dark hover:shadow-[0_12px_32px_-8px_rgba(158,78,66,0.45)]"
              >
                Quiero mi primera hora gratis
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <div class="rounded-2xl border border-hairline bg-[#f8f9fa] p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
              <h3 class="font-display text-xl text-ink">WhatsApp directo</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Si preferís escribir libre, sin pasar por el form.
              </p>
              <p class="mt-2 text-sm text-ink-soft">
                Dejá tu mensaje y te respondemos en cuanto podemos.
              </p>
              <a
                href={CONTACT.whatsappLink()}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {CONTACT.whatsappLeadsDisplay}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
              <h3 class="font-display text-xl text-ink">Email</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Para temas más largos o si te queda más cómodo.
              </p>
              <a
                href={`mailto:${CONTACT.email}`}
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {CONTACT.email}
              </a>
            </div>

            <div class="rounded-2xl border border-hairline bg-[#f8f9fa] p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
              <h3 class="font-display text-xl text-ink">Visitanos</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Escribinos por WhatsApp y coordinamos tu visita
                sin compromiso.
              </p>
              <address class="mt-2 not-italic text-sm leading-relaxed text-ink-soft">
                {ADDRESS.street}<br />
                {ADDRESS.betweenStreets}<br />
                {ADDRESS.neighborhood}, {ADDRESS.city}
              </address>
              <div class="mt-4 overflow-hidden rounded-xl border border-hairline">
                <iframe
                  title="Mapa de Espacio 1010 — Gaboto 1010, Montevideo"
                  src="https://www.google.com/maps?q=Gaboto%201010%20Montevideo%20Uruguay&output=embed"
                  width="100%"
                  height="220"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  style="border:0; display:block;"
                ></iframe>
              </div>
              <p class="mt-3 text-xs text-ink-muted">
                Zona con estacionamiento NO tarifado · bien conectada en bus.
              </p>
              <a
                href={ADDRESS.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                Ver en mapa
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
              <h3 class="font-display text-xl text-ink">Instagram</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Mostramos cómo va el edificio, novedades y momentos del día a día.
              </p>
              <a
                href={SOCIAL.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {SOCIAL.instagramHandle}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>
