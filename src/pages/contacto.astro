---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import ContactForm from '../components/ContactForm.tsx';
import { CONTACT, ADDRESS, SOCIAL } from '../lib/site';

// Número WhatsApp para el form — sin "+", para wa.me
const waNumber = CONTACT.whatsappLeads.replace(/[^0-9]/g, '');
---

<BaseLayout
  title="Contacto"
  description="Coordiná visita guiada, resolvé dudas o pedí info sobre precios y disponibilidad. Te respondemos por WhatsApp todos los días en horario comercial."
  ogSlug="contacto"
>
  <section class="pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Contacto
      </p>
      <h1 class="text-balance">
        Hablamos
        <span class="italic text-terracota">cuando querés</span>.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        WhatsApp es nuestro canal principal — atendemos rápido, en horario
        comercial. Si preferís mail, también va. La visita guiada se coordina
        sin compromiso.
      </p>
    </Container>
  </section>

  <section class="pb-24">
    <Container>
      <div class="grid gap-12 md:grid-cols-12">
        <!-- Form -->
        <div class="md:col-span-7">
          <div class="rounded-[var(--radius-lg)] border border-hairline bg-crema p-8 sm:p-10">
            <h2 class="font-display text-2xl text-ink">Escribinos</h2>
            <p class="mt-2 text-sm text-ink-soft">
              Completá esto y abrimos WhatsApp con el mensaje listo. Tardás 20 segundos.
            </p>

            <div class="mt-8">
              <ContactForm client:load whatsappNumber={waNumber} />
            </div>
          </div>
        </div>

        <!-- Otros canales -->
        <aside class="md:col-span-5">
          <div class="sticky top-24 space-y-6">
            <div class="rounded-[var(--radius-lg)] border border-hairline bg-crema p-7">
              <h3 class="font-display text-xl text-ink">WhatsApp directo</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Si preferís escribir libre, sin pasar por el form.
              </p>
              <a
                href={CONTACT.whatsappLink()}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {CONTACT.whatsappLeadsDisplay}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <div class="rounded-[var(--radius-lg)] border border-hairline bg-crema p-7">
              <h3 class="font-display text-xl text-ink">Email</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Para temas más largos o si te queda más cómodo.
              </p>
              <a
                href={`mailto:${CONTACT.email}`}
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {CONTACT.email}
              </a>
            </div>

            <div class="rounded-[var(--radius-lg)] border border-hairline bg-crema p-7">
              <h3 class="font-display text-xl text-ink">Visitanos</h3>
              <address class="mt-2 not-italic text-sm leading-relaxed text-ink-soft">
                {ADDRESS.street}<br />
                {ADDRESS.betweenStreets}<br />
                {ADDRESS.neighborhood}, {ADDRESS.city}
              </address>
              <a
                href={ADDRESS.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                Ver en mapa
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <div class="rounded-[var(--radius-lg)] border border-hairline bg-crema p-7">
              <h3 class="font-display text-xl text-ink">Instagram</h3>
              <p class="mt-2 text-sm text-ink-soft">
                Mostramos cómo va el edificio, novedades y momentos del día a día.
              </p>
              <a
                href={SOCIAL.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
              >
                {SOCIAL.instagramHandle}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>
</BaseLayout>
