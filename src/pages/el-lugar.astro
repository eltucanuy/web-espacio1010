---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { ADDRESS, AMENITIES, CONTACT } from '../lib/site';
---

<BaseLayout
  title="El lugar: Gaboto 1010, entre Palermo y Parque Rodó"
  description="Edificio centenario en Gaboto 1010, entre Palermo y Parque Rodó, reciclado para consultorios y salas por hora. Historia, amenities y cómo llegar a Espacio 1010."
  ogSlug="el-lugar"
>
  <!-- Hero -->
  <section class="bg-white pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        El lugar
      </p>
      <h1 class="text-balance">
        Una casa con
        <span class="text-terracota">100 años</span>,
        puesta a punto para los próximos 100.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        Compramos una casa entre Palermo y Parque Rodó, llena de historia, y la
        reciclamos a cero sin perder lo que la hacía única. Cada piso, cada
        moldura, cada carpintería original que se podía rescatar, se rescató.
        Lo nuevo se sumó con respeto.
      </p>
    </Container>
  </section>

  <!-- Visual del edificio -->
  <section class="bg-white pb-20 sm:pb-24">
    <Container size="wide">
      <div class="relative aspect-[16/9] overflow-hidden rounded-[var(--radius-xl)] border border-hairline shadow-[var(--shadow-md)]">
        <img
          src="/fotos/fachada-final.webp"
          alt="Fachada reciclada del edificio de Espacio 1010, iluminada de noche, entre Palermo y Parque Rodó"
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </Container>
  </section>

  <!-- Historia + filosofía -->
  <section class="bg-white py-16 sm:py-20">
    <Container size="narrow">
      <h2 class="text-3xl text-ink sm:text-4xl">Reciclar sin tapar.</h2>
      <div class="mt-8 space-y-6 text-lg leading-relaxed text-ink-soft text-pretty">
        <p>
          La casa de Gaboto 1010 estuvo abandonada durante años. Cuando la
          encontramos, faltaba estructura y sobraba humedad — pero las
          aberturas, los pisos calcáreos y la altura de los techos pedían
          una segunda oportunidad. Decidimos dársela.
        </p>
        <p>
          La obra fue lenta a propósito. Donde había madera buena, la
          recuperamos. Donde había revoque sano, lo dejamos. Donde no, sumamos
          piezas contemporáneas sin imitar a las viejas. El resultado es un
          edificio que no esconde su historia, pero tampoco la usa de
          escenografía.
        </p>
        <p>
          Adentro, la tecnología no se nota: wifi en todo el edificio, aire
          acondicionado en cada espacio y acceso con tu código personal. La idea
          es que cuando entres, lo único en lo que pienses sea la persona que
          vas a atender.
        </p>
        <p>
          ¿Querés ver los consultorios y salas?
          <a href="/los-espacios" class="font-semibold text-terracota underline-offset-4 hover:underline">Conocé los espacios</a>.
        </p>
      </div>
    </Container>
  </section>

  <!-- Galería — fotos reales de las áreas comunes -->
  <section class="bg-white pb-16 sm:pb-20">
    <Container size="wide">
      <p class="flex items-center justify-end gap-1.5 text-xs text-ink-soft/70 lg:hidden">
        Deslizá para ver más
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </p>
      <div class="mt-3 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-3 lg:mt-0 lg:block lg:columns-3 lg:gap-4 lg:overflow-visible lg:pb-0 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {
          [
            { src: '/fotos/lugar-pasillo.webp', lg: 'lg:aspect-[3/4]', cap: 'Pasillo · ladrillo a la vista', alt: 'Pasillo de Espacio 1010 con muro de ladrillo original a la vista, lámparas circulares y claraboya' },
            { src: '/fotos/lugar-subsuelo.webp', lg: 'lg:aspect-[3/2]', cap: 'Subsuelo · piedra y arco originales', alt: 'Subsuelo de Espacio 1010 con muro de piedra y arco original iluminado, piso de madera' },
            { src: '/fotos/lugar-herreria.webp', lg: 'lg:aspect-[3/4]', cap: 'Herrería original recuperada', alt: 'Detalle de la herrería original de la baranda, con roseta de bronce, sobre muro de ladrillo' },
            { src: '/fotos/lugar-marmol.webp', lg: 'lg:aspect-[3/4]', cap: 'Escalera de mármol original', alt: 'Escalera de mármol original de Espacio 1010 junto a un muro de ladrillo a la vista' },
            { src: '/fotos/lugar-sala-subsuelo.webp', lg: 'lg:aspect-[3/2]', cap: 'Sala del subsuelo', alt: 'Sala amplia del subsuelo de Espacio 1010 con muro de piedra, piso de madera y escalera metálica' },
            { src: '/fotos/lugar-circulacion.webp', lg: 'lg:aspect-[3/4]', cap: 'Circulación con luz natural', alt: 'Circulación de Espacio 1010 con lámparas circulares colgantes y luz natural al fondo' },
          ].map((f) => (
            <figure class="group w-[80%] shrink-0 snap-start overflow-hidden rounded-[var(--radius-xl)] border border-hairline shadow-[var(--shadow-md)] sm:w-[46%] lg:mb-4 lg:w-full lg:break-inside-avoid">
              <div class={`relative aspect-[3/4] overflow-hidden ${f.lg}`}>
                <img
                  src={f.src}
                  alt={f.alt}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-out-soft)] group-hover:scale-105"
                />
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent p-4 pt-12">
                  <p class="text-sm font-medium text-white">{f.cap}</p>
                </div>
              </div>
            </figure>
          ))
        }
      </div>
      <p class="mt-6 text-center text-sm text-ink-soft">
        Fotos reales de las áreas comunes. Fotos de cada espacio, muy pronto.
      </p>
    </Container>
  </section>

  <!-- Amenities completos -->
  <section class="bg-[#f8f9fa] py-16 sm:py-24">
    <Container>
      <div class="max-w-2xl">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
          Amenities
        </p>
        <h2 class="text-3xl text-ink sm:text-4xl">Todo lo que viene incluido.</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft text-pretty">
          Sin extras escondidos. Sin "items facturables aparte". Tu reserva
          incluye el espacio y todo el edificio que lo rodea, por $350 la hora.
          <a href="/precios" class="font-semibold text-terracota underline-offset-4 hover:underline">Mirá precios y descuentos</a>.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          AMENITIES.map((a) => (
            <div class="flex items-start gap-4 rounded-2xl border border-hairline bg-white p-5 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
              <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <p class="text-base leading-snug text-ink">{a.label}</p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- Ubicación -->
  <section class="bg-white py-16 sm:py-24">
    <Container size="wide">
      <div class="grid gap-10 md:grid-cols-12 md:items-center">
        <div class="md:col-span-5">
          <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
            Ubicación
          </p>
          <h2 class="text-3xl text-ink sm:text-4xl">
            Entre Palermo y Parque Rodó, a un paso de todo.
          </h2>
          <address class="mt-6 not-italic">
            <p class="text-2xl font-semibold text-ink">{ADDRESS.street}</p>
            <p class="text-base text-ink-soft">{ADDRESS.betweenStreets}</p>
            <p class="mt-1 text-base text-ink-soft">{ADDRESS.city}, {ADDRESS.country}</p>
          </address>

          <ul class="mt-8 space-y-3 text-base text-ink-soft">
            <li class="flex items-start gap-3">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                <circle cx="12" cy="10" r="3" />
                <path d="M12 2C8 2 5 5 5 9c0 5.5 7 13 7 13s7-7.5 7-13c0-4-3-7-7-7z" />
              </svg>
              A pocas cuadras del Parque Rodó y a minutos de 18 de Julio
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                <rect x="3" y="6" width="18" height="12" rx="2" />
                <path d="M3 12h18" />
              </svg>
              A 2 cuadras de líneas troncales de transporte público
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 8v8M8 12h8" stroke-linecap="round" />
              </svg>
              Estacionamiento fácil en la zona (no tarifado)
            </li>
          </ul>

          <div class="mt-10 flex flex-wrap gap-3">
            <Button href={ADDRESS.mapsUrl} variant="primary" size="md" target="_blank">
              Abrir en Google Maps
            </Button>
            <Button href="/contacto" variant="ghost" size="md">
              Coordinar una visita
            </Button>
          </div>
        </div>

        <div class="md:col-span-7">
          <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--radius-xl)] border border-hairline bg-[#f8f9fa]">
            <iframe
              title="Mapa de Espacio 1010 en Gaboto 1010, Montevideo"
              src="https://www.google.com/maps?q=Gaboto%201010%20Montevideo%20Uruguay&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="h-full w-full"
              style="border: 0;"
            ></iframe>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Accesibilidad — honestidad como diferencial -->
  <section class="bg-[#f8f9fa] py-16 sm:py-24">
    <Container size="narrow">
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Accesibilidad
      </p>
      <h2 class="text-3xl text-ink sm:text-4xl">
        Lo que sí, y lo que coordinamos juntos.
      </h2>
      <div class="mt-8 space-y-5 text-lg leading-relaxed text-ink-soft text-pretty">
        <p>
          Planta baja con baño totalmente accesible y dimensiones de pasillos
          aptas para silla de ruedas dentro del edificio.
        </p>
        <p>
          El acceso desde la calle tiene <strong class="text-ink">dos
          escalones</strong>. Si vos o tu paciente necesitan asistencia,
          coordinamos por WhatsApp y los recibimos en la puerta — sin
          improvisaciones.
        </p>
        <p>
          Es algo que decidimos contarte explícitamente: preferimos eso a que
          te enteres llegando.
        </p>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20 sm:py-28">
    <Container>
      <div class="rounded-[var(--radius-xl)] bg-ink p-12 text-center text-white sm:p-20">
        <h2 class="text-balance text-white">Venite a conocerlo.</h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/80">
          Registrate gratis y asegurá tu primera hora sin cargo, para usarla
          cuando quieras. ¿Querés verlo antes? Coordinamos una visita por WhatsApp.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href="/#registro" variant="primary" size="lg" class="bg-white text-terracota hover:bg-white/90">
            Quiero mi primera hora gratis
          </Button>
          <Button href={CONTACT.whatsappLink('Hola! Quiero coordinar una visita a Espacio 1010.')} variant="ghost" size="lg" class="text-white hover:bg-white/10" target="_blank">
            Coordinar visita por WhatsApp
          </Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
