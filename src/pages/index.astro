  <!-- ════════════════════ BARRA CTA STICKY (solo mobile) ════════════════════ -->
  <div
    id="sticky-cta"
    class="fixed inset-x-0 bottom-0 z-30 border-t border-hairline bg-white/95 px-4 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] shadow-[0_-6px_24px_-10px_rgba(0,0,0,0.25)] backdrop-blur-sm transition-transform duration-300 sm:hidden"
    style="transform: translateY(120%);"
  >
    <a href="#registro" class="flex h-12 w-full items-center justify-center gap-2 rounded-full bg-terracota text-sm font-semibold text-white">
      Quiero mi primera hora gratis
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</LandingLayout>

<script>
  // Barra CTA sticky en mobile: aparece al salir del hero y se esconde cuando el
  // form de registro entra en pantalla (para no duplicar el botón). Empuja el botón
  // flotante de WhatsApp hacia arriba mientras está visible, solo en mobile.
  const bar = document.getElementById('sticky-cta');
  const hero = document.getElementById('hero');
  const registro = document.getElementById('registro');
  const wa = document.querySelector<HTMLElement>('[data-floating-wa]');
  const isMobile = () => window.matchMedia('(max-width: 639px)').matches;

  let pastHero = false;
  let registroVisible = false;

  const apply = () => {
    const show = pastHero && !registroVisible;
    if (bar) bar.style.transform = show ? 'translateY(0)' : 'translateY(120%)';
    if (wa) wa.style.bottom = show && isMobile() ? '5.75rem' : '';
  };

  if (bar && hero && registro) {
    new IntersectionObserver(
      (entries) => { entries.forEach((e) => { pastHero = !e.isIntersecting; }); apply(); },
      { threshold: 0.1 }
    ).observe(hero);
    new IntersectionObserver(
      (entries) => { entries.forEach((e) => { registroVisible = e.isIntersecting; }); apply(); },
      { threshold: 0.1 }
    ).observe(registro);
  }
</script>

<script>
  import { createClient } from '@supabase/supabase-js';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = url && key ? createClient(url, key) : null;
  const CUPON_URL = 'https://agenda.espacio1010.uy/c/BIENVENIDA1010';

  const form = document.getElementById('preregistro-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('f-error');
  const submitBtn = document.getElementById('f-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    // Honeypot: si un bot llenó el campo oculto, abortamos en silencio.
    const honeypot = (form.querySelector('[name="company"]') as HTMLInputElement)?.value;
    if (honeypot) return;

    const nombre = (form.querySelector('[name="nombre"]') as HTMLInputElement).value.trim();
    const apellido = (form.querySelector('[name="apellido"]') as HTMLInputElement).value.trim();
    const telRaw = (form.querySelector('[name="telefono"]') as HTMLInputElement).value;
    let telefono = telRaw.replace(/\D/g, '');
    if (telefono.startsWith('598')) telefono = telefono.slice(3); // por si ponen el código de país
    const telOk = /^09\d{7}$/.test(telefono); // celular uruguayo: 09 + 7 dígitos
    const consent = (document.getElementById('f-consent') as HTMLInputElement)?.checked;

    if (errorEl) { errorEl.classList.add('hidden'); errorEl.textContent = ''; }

    if (!nombre || !apellido) {
      if (errorEl) { errorEl.textContent = 'Completá nombre y apellido.'; errorEl.classList.remove('hidden'); }
      return;
    }
    if (!telOk) {
      if (errorEl) { errorEl.textContent = 'Ingresá un celular uruguayo válido (ej. 099 123 456).'; errorEl.classList.remove('hidden'); }
      return;
    }
    if (!consent) {
      if (errorEl) { errorEl.textContent = 'Necesitamos tu OK para contactarte.'; errorEl.classList.remove('hidden'); }
      return;
    }

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Un segundo…'; }

    // Parámetros de la URL actual (UTMs de la campaña, si vino de Ads).
    const p = new URLSearchParams(location.search);

    // Destino: la PWA con cupón + campos precargados + UTMs reenviadas, para que
    // la PWA pueda atribuir la "cuenta creada" a la campaña que trajo el lead.
    const q = new URLSearchParams({ nombre, apellido, telefono });
    for (const k of ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term']) {
      const v = p.get(k);
      if (v) q.set(k, v);
    }
    const destino = `${CUPON_URL}?${q.toString()}`;

    // Mostramos el éxito YA (pantalla completa), sin esperar al guardado.
    const exito = document.getElementById('preregistro-exito');
    const nombreEl = document.getElementById('exito-nombre');
    const continuar = document.getElementById('exito-continuar') as HTMLAnchorElement | null;
    if (nombreEl && nombre) nombreEl.textContent = `, ${nombre}`;
    if (continuar) continuar.href = destino;
    if (exito) exito.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    // Guardado del lead + evento de conversión, en paralelo (no bloquean la UX).
    const lead = {
      nombre, apellido, telefono,
      origen: 'landing',
      utm_source: p.get('utm_source'),
      utm_medium: p.get('utm_medium'),
      utm_campaign: p.get('utm_campaign'),
    };
    if (supabase) {
      supabase.from('pre_registros').insert(lead).then(
        () => {},
        (err: unknown) => console.warn('lead insert failed', err)
      );
    }
    (window as any).dataLayer = (window as any).dataLayer || [];
    (window as any).dataLayer.push({ event: 'lead_preregistro' });

    // Redirige sola tras unos segundos (el botón "Continuar ahora" permite adelantarlo).
    setTimeout(() => { location.href = destino; }, 3000);
  });
</script>
