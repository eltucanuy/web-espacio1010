---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Diferenciales from '../components/sections/Diferenciales.astro';
import EspaciosPreview from '../components/sections/EspaciosPreview.astro';
import ComoFunciona from '../components/sections/ComoFunciona.astro';
import TarifaFundadores from '../components/sections/TarifaFundadores.astro';
import ParaProfesionales from '../components/sections/ParaProfesionales.astro';
import ElLugarTeaser from '../components/sections/ElLugarTeaser.astro';
import CTAFinal from '../components/sections/CTAFinal.astro';
---

<BaseLayout
  title="Espacios boutique por hora para profesionales"
  description="Reservá consultorio por hora en pleno Cordón, Montevideo. 12 espacios premium, autogestión 24/7, política de cancelación flexible. Para psicólogos, psiquiatras, nutricionistas y profesionales del bienestar."
>
  <Hero />
  <Diferenciales />
  <EspaciosPreview />
  <ComoFunciona />
  <TarifaFundadores />
  <ParaProfesionales />
  <ElLugarTeaser />
  <CTAFinal />
</BaseLayout>
