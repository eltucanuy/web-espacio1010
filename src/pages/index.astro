<script>
  // Barra CTA sticky en mobile: aparece al salir del hero y se esconde cuando el
  // form de registro entra en pantalla (para no duplicar el botón). Empuja el botón
  // flotante de WhatsApp hacia arriba mientras está visible, solo en mobile.
  const bar = document.getElementById('sticky-cta');
  const hero = document.getElementById('hero');
  const registro = document.getElementById('registro');
  const wa = document.querySelector<HTMLElement>('[data-floating-wa]');
  const isMobile = () => window.matchMedia('(max-width: 639px)').matches;

  let pastHero = false;
  let registroVisible = false;

  const apply = () => {
    const show = pastHero && !registroVisible;
    if (bar) bar.style.transform = show ? 'translateY(0)' : 'translateY(120%)';
    if (wa) wa.style.bottom = show && isMobile() ? '5.75rem' : '';
  };

  if (bar && hero && registro) {
    new IntersectionObserver(
      (entries) => { entries.forEach((e) => { pastHero = !e.isIntersecting; }); apply(); },
      { threshold: 0.1 }
    ).observe(hero);
    new IntersectionObserver(
      (entries) => { entries.forEach((e) => { registroVisible = e.isIntersecting; }); apply(); },
      { threshold: 0.1 }
    ).observe(registro);
  }
</script>

<script>
  // Carruseles de fotos en las cards de "Los espacios": swipe nativo (scroll-snap)
  // + flechas (desktop, en hover) + puntitos que reflejan la foto activa.
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((car) => {
    const track = car.querySelector<HTMLElement>('[data-track]');
    if (!track) return;
    const dots = Array.from(car.querySelectorAll<HTMLElement>('[data-dot]'));
    const slideWidth = () => track.clientWidth;

    const syncDots = () => {
      const i = Math.round(track.scrollLeft / slideWidth());
      dots.forEach((d, j) => {
        d.classList.toggle('w-4', j === i);
        d.classList.toggle('opacity-100', j === i);
        d.classList.toggle('w-1.5', j !== i);
        d.classList.toggle('opacity-60', j !== i);
      });
    };

    let raf = 0;
    track.addEventListener('scroll', () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(syncDots);
    }, { passive: true });

    const go = (dir: number) => {
      const i = Math.round(track.scrollLeft / slideWidth());
      const next = Math.max(0, Math.min(dots.length - 1, i + dir));
      track.scrollTo({ left: next * slideWidth(), behavior: 'smooth' });
    };
    car.querySelector('[data-prev]')?.addEventListener('click', () => go(-1));
    car.querySelector('[data-next]')?.addEventListener('click', () => go(1));
    dots.forEach((d, j) => d.addEventListener('click', () => track.scrollTo({ left: j * slideWidth(), behavior: 'smooth' })));
  });
</script>

