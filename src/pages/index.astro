---
/**
 * HOME (/) — Landing de conversión de producción.
 *
 * Objetivo único: pre-registro. Flujo: form (nombre/apellido/WhatsApp) → guarda lead
 * en Supabase (pre_registros) + evento GTM 'lead_preregistro' → redirige a la PWA con
 * el cupón BIENVENIDA1010 y los 3 campos precargados.
 *
 * Mobile-first: casi todo el tráfico entra desde el celular (una sola columna vertical).
 * La jerarquía se logra con orden + tamaño, no con columnas.
 * Orden: Hero → Pensado para que digas que sí → Los espacios → Cómo funciona → Seguridad → Form.
 */
import LandingLayout from '../layouts/LandingLayout.astro';
import Container from '../components/Container.astro';
import { ADDRESS } from '../lib/site';

const PRECIO_HORA = 350;
const PRECIO_ARCOS = 700;
const CUPON_URL = 'https://agenda.espacio1010.uy/c/BIENVENIDA1010';

const pasos = [
  { n: '01', t: 'Te pre-registrás ahora', d: 'Gratis, en 30 segundos, desde el celular. Sin tarjeta, sin permanencia. Tu primera hora queda reservada a tu nombre.' },
  { n: '02', t: 'Ves disponibilidad real', d: 'La agenda de los 12 espacios, en vivo. Lo que ves disponible, está disponible.' },
  { n: '03', t: 'Reservás en 1 minuto', d: 'Elegís espacio, día y hora. Confirmación al instante, sin esperar a nadie.' },
  { n: '04', t: 'Entrás con tu código', d: 'Tu código personal abre las puertas 24/7. Llegás y atendés, con todo a punto.' },
];

/**
 * "Pensado para que digas que sí" — 3 niveles de jerarquía.
 * Nivel 1: cancelación (bloque protagonista, oscuro). Ver `cancelacion`.
 * Nivel 2: beneficios medianos (3 cards). Nivel 3: el resto, compacto (6 ítems chicos).
 */
const cancelacion = [
  { cuando: 'Hasta 24 h antes', que: 'Cancelás gratis', detalle: 'No pagás nada. Tu hora vuelve a quedar disponible.', destacado: true },
  { cuando: 'Hasta 1 h antes', que: 'Pagás solo el 50%', detalle: 'Tu día cambió sobre la hora: cubrís la mitad, no la hora entera.', destacado: false },
];

const nivel2 = [
  { t: 'Agenda en tu celular', d: 'Ves la disponibilidad real de los 12 espacios y reservás en menos de un minuto, sin esperar a nadie.', icon: 'calendar' },
  { t: 'Acceso de lunes a domingo, las 24 horas', d: 'Tu código personal abre las puertas cualquier día, a cualquier hora. Vos manejás tus tiempos.', icon: 'lock' },
  { t: 'Confiamos en vos desde el día 1', d: 'Empezás sin poner plata: probás el espacio y pagás recién a mes vencido, sin tarjeta.', icon: 'wallet' },
];

const nivel3 = [
  { t: `Precio único: $${PRECIO_HORA}/h`, icon: 'tag' },
  { t: 'Descuentos por volumen', icon: 'trend' },
  { t: 'Cocina y sala sin cargo', icon: 'coffee' },
  { t: 'Estacionamiento sin parquímetro', icon: 'car' },
  { t: 'Bien conectado en bus', icon: 'bus' },
  { t: 'Edificio reciclado a nuevo', icon: 'sparkle' },
];

// Seguridad — comprimida a un bloque chico de etiquetas (solo lo confirmado).
const seguridadPills = [
  'Cerrado 24/7',
  'Código con registro',
  'Cámaras',
  'Videoportero',
  'Bien iluminado',
];

// Testimonios reales, aprobados por cada persona (prueba social).
const testimonios = [
  {
    texto: 'Lo fui a ver y me alegró un montón. Es un lugar generoso —mucha luz, espacios grandes—, de esos donde dan ganas de quedarse a trabajar.',
    nombre: 'Gastón', rol: 'Instructor del Bach Centre', edad: 50, inicial: 'G',
  },
  {
    texto: 'Es justo la vuelta que estaba buscando. Coordinar agenda con los pacientes siempre fue un ida y vuelta eterno; con esto voy a poder reservar todo desde el celular, cuando quiera, sin depender de nadie. Simple y rápido.',
    nombre: 'Claudia', rol: 'Psicóloga', edad: 36, inicial: 'C',
  },
  {
    texto: 'Para lo que hago necesito de todo: a veces un grupo grande, a veces algo más chico, a veces una consulta sola. Tener todo en un mismo lugar me va a resolver la vida. Y poder trabajar un fin de semana o bien temprano a la mañana, para mí no tiene precio.',
    nombre: 'Patricia', rol: 'Consteladora familiar', edad: 62, inicial: 'P',
  },
  {
    texto: 'Trabajo con grupos chicos, y acá voy a poder armar el espacio como quiera, con colchonetas y todo, pagando como un individual y no como un salón. Eso para mí es un montón. Y encima el edificio es divino, toda esa madera original tiene una historia.',
    nombre: 'Maite', rol: 'Método Feldenkrais', edad: 39, inicial: 'M',
  },
];

const espacios = [
  { nombre: 'Consultorios acogedores', nota: 'Psicología · psiquiatría', cap: '2 personas', precio: PRECIO_HORA, icon: 'sofa' },
  { nombre: 'Escritorios luminosos', nota: 'Nutrición · consulta clínica', cap: '2 a 3 personas', precio: PRECIO_HORA, icon: 'desk' },
  { nombre: 'Salas de terapia', nota: 'Psicoanálisis · coaching', cap: '2 personas', precio: PRECIO_HORA, icon: 'chair' },
  { nombre: 'Sala Arcos', nota: 'Grupos · talleres · yoga', cap: 'hasta 30', precio: PRECIO_ARCOS, icon: 'group' },
];

const iconPaths: Record<string, string> = {
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/><circle cx="12" cy="16" r="1.2"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/>',
  wallet: '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><circle cx="17" cy="14" r="1.3"/>',
  trend: '<path d="M3 17l6-6 4 4 7-8"/><path d="M21 7v4h-4"/>',
  tag: '<path d="M3 12l8-8h8v8l-8 8-8-8z"/><circle cx="15" cy="9" r="1.4"/>',
  sofa: '<path d="M4 11V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M2 13a2 2 0 0 1 4 0v3h12v-3a2 2 0 0 1 4 0v5H2z"/>',
  desk: '<path d="M3 7h18M5 7v13M19 7v13M4 12h7"/><rect x="13" y="11" width="7" height="5" rx="1"/>',
  chair: '<path d="M6 4v8h12V4M5 12h14M8 19l1-7M16 19l-1-7"/>',
  group: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 20a6 6 0 0 1 12 0M15 20a5 5 0 0 1 6-3.5"/>',
  bell: '<path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>',
  camera: '<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>',
  bulb: '<path d="M9 18h6M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V18h6v-1.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/>',
  coffee: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z"/><path d="M6 1v3M10 1v3M14 1v3"/>',
  car: '<path d="M5 11l1.6-4.4A2 2 0 0 1 8.5 5h7a2 2 0 0 1 1.9 1.4L19 11"/><path d="M3 11h18v5a1 1 0 0 1-1 1h-2v-2H6v2H4a1 1 0 0 1-1-1z"/><circle cx="7.5" cy="14.5" r="1"/><circle cx="16.5" cy="14.5" r="1"/>',
  bus: '<rect x="4" y="3" width="16" height="14" rx="2"/><path d="M4 11h16"/><path d="M7 17v2M17 17v2"/><circle cx="8.5" cy="14" r="1"/><circle cx="15.5" cy="14" r="1"/>',
  sparkle: '<path d="M12 3l1.8 5.2L19 11l-5.2 1.8L12 18l-1.8-5.2L5 11l5.2-2z"/>',
};
---

<LandingLayout
  title="Alquilá tu consultorio por hora, sin costos fijos"
  description="Alquilá uno de los 12 consultorios y salas boutique por hora de Espacio 1010, entre Palermo y Parque Rodó, Montevideo. Sin alquiler fijo ni permanencia. Pre-registrate y asegurá tu primera hora gratis para usar durante 2026."
>
  <!-- ════════════════════ HERO (sin la captura: se movió a Cómo funciona) ════════════════════ -->
  <section id="hero" class="relative overflow-hidden text-white">
    <img src="/fotos/fachada.jpg" alt="Fachada del edificio de Espacio 1010, entre Palermo y Parque Rodó" class="absolute inset-0 -z-20 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-ink/92 via-ink/85 to-ink/70"></div>
    <div class="absolute -right-32 -top-24 -z-10 h-[420px] w-[420px] rounded-full opacity-40 blur-3xl" style="background: radial-gradient(circle, #9e4e42 0%, transparent 70%);" aria-hidden="true"></div>

    <Container class="py-14 sm:py-20 md:py-24">
      <div class="max-w-2xl">
        <p class="mb-5 inline-flex items-center gap-2 whitespace-nowrap rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-medium text-white/90 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-terracota-light opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-terracota-light"></span>
          </span>
          Pre-lanzamiento · ¡muy pronto!
        </p>

        <h1 class="mt-2 text-balance text-white">
          Alquilá tu consultorio por hora, sin costos fijos.
          <span class="block text-terracota-light">Tu primera hora, gratis.</span>
        </h1>

        <p class="mt-5 max-w-xl text-base leading-relaxed text-white/80 text-pretty">12 espacios boutique entre Palermo y Parque Rodó. Reservás y entrás 100% desde el celular.</p>

        <ul class="mt-6 flex flex-wrap gap-2" aria-label="Para quién es Espacio 1010">
          {['Psicología', 'Psiquiatría', 'Psicopedagogía', 'Nutrición', 'Yoga y meditación', 'Talleres'].map((n) => (
            <li class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-medium text-white/85 backdrop-blur-sm">{n}</li>
          ))}
        </ul>

        <p class="mt-6 max-w-xl text-base leading-relaxed text-white/80 text-pretty">Registrate hoy y tu hora gratis queda a tu nombre para usarla cuando quieras en 2026.</p>

        <div class="mt-8">
          <a href="#registro" class="inline-flex h-14 w-full items-center justify-center gap-2 rounded-full bg-terracota px-9 text-base font-semibold text-white transition-all duration-300 ease-[var(--ease-out-soft)] hover:-translate-y-0.5 hover:bg-terracota-light sm:w-auto">
            Quiero mi primera hora gratis
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <p class="mt-3 text-xs text-white/70">Sin tarjeta · sin permanencia · no pagás nada hasta reservar</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ PENSADO PARA QUE DIGAS QUE SÍ (3 niveles) ════════════════════ -->
  <section class="bg-[#f8f9fa] py-16 sm:py-24">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">Por qué 1010</p>
        <h2 class="text-3xl text-ink sm:text-4xl">Pensado para que digas que sí.</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft text-pretty">Nada de idas y vueltas, ni horarios rígidos, ni extras escondidos. La tecnología desaparece y vos te dedicás a lo que importa.</p>
      </div>

      <!-- Nivel 1: cancelación, bloque protagonista (oscuro) -->
      <div class="mt-12 overflow-hidden rounded-3xl bg-ink p-8 text-white shadow-[var(--shadow-md)] sm:p-10">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota-light">Cancelación flexible</p>
          <h3 class="mt-3 text-2xl font-bold sm:text-3xl">A vos también te cancelan. Acá no lo pagás.</h3>
          <p class="mt-4 text-base leading-relaxed text-white/70">Cancelás con la misma flexibilidad que vos les das a tus pacientes — sin penalización ni letra chica.</p>
        </div>
        <div class="mx-auto mt-8 grid max-w-2xl gap-4 sm:grid-cols-2">
          {cancelacion.map((c) => (
            <div class={`rounded-2xl p-6 ${c.destacado ? 'bg-terracota' : 'bg-white/[0.06]'}`}>
              <p class={`text-xs font-semibold uppercase tracking-wider ${c.destacado ? 'text-white/85' : 'text-white/55'}`}>{c.cuando}</p>
              <p class="mt-2 text-2xl font-bold text-white">{c.que}</p>
              <p class={`mt-2 text-sm leading-relaxed ${c.destacado ? 'text-white/90' : 'text-white/65'}`}>{c.detalle}</p>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-2xl text-center text-sm text-white/60">¿Tenés día y hora fijos cada semana? Tus reservas fijas incluyen cancelaciones sin cargo todos los meses.</p>
      </div>

      <!-- Nivel 2: beneficios medianos -->
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {nivel2.map((v) => (
          <div class="rounded-2xl border border-hairline bg-white p-6 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[v.icon]} />
            </span>
            <h3 class="mt-5 text-lg text-ink">{v.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{v.d}</p>
          </div>
        ))}
      </div>

      <!-- Nivel 3: el resto, en filas compactas (ícono + etiqueta corta) -->
      <div class="mt-4 grid gap-2.5 sm:grid-cols-2 lg:grid-cols-3">
        {nivel3.map((v) => (
          <div class="flex items-center gap-3 rounded-xl border border-hairline bg-white px-4 py-3">
            <span class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-terracota-tint text-terracota">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[v.icon]} />
            </span>
            <span class="text-sm font-medium leading-snug text-ink">{v.t}</span>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="#registro" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-terracota px-7 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-terracota-light">
          Quiero mi primera hora gratis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ LOS ESPACIOS (cards tipográficas, sin fotos) ════════════════════ -->
  <section class="bg-white py-16 sm:py-24">
    <Container size="wide">
      <div class="mx-auto max-w-2xl text-center">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">Los espacios</p>
        <h2 class="text-3xl text-ink sm:text-4xl">Uno para cada práctica.</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft text-pretty">12 espacios amoblados, climatizados e insonorizados, entre Palermo y {ADDRESS.neighborhood}. Desde consultas individuales hasta la Sala Arcos para grupos y talleres.</p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {espacios.map((e) => (
          <article class="flex flex-col rounded-2xl border border-hairline bg-[#f8f9fa] p-6 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[e.icon]} />
            </span>
            <h3 class="mt-5 text-lg text-ink">{e.nombre}</h3>
            <p class="mt-1 text-sm text-ink-soft">{e.nota}</p>
            <p class="mt-1 text-xs text-ink-muted">{e.cap}</p>
            <p class="mt-4 text-sm font-semibold text-terracota">${e.precio} <span class="font-normal text-ink-muted">/ hora</span></p>
          </article>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-ink-muted">Fotos reales de cada espacio, muy pronto.</p>
      <div class="mt-10 text-center">
        <a href="#registro" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-terracota px-7 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-terracota-light">
          Quiero mi primera hora gratis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ CÓMO FUNCIONA (con la captura de la app) ════════════════════ -->
  <section class="bg-[#f8f9fa] py-16 sm:py-24">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">Cómo funciona</p>
        <h2 class="text-3xl text-ink sm:text-4xl">De cero a reservado, en cuatro pasos.</h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft text-pretty">Todo el flujo vive en tu celular. Sin papeleo, sin llamadas, sin recepción.</p>
      </div>

      <!-- Captura real de la app (movida desde el hero) -->
      <div class="mx-auto mt-10 w-full max-w-[240px]">
        <div class="relative overflow-hidden rounded-[2.2rem] border-[7px] border-[#0f0c0e] bg-[#0f0c0e] shadow-[var(--shadow-md)]">
          <img
            src="/fotos/app-captura.png"
            alt="Pantalla de la app de Espacio 1010: elegís espacio, día y hora y reservás desde el celular"
            width="460"
            height="912"
            loading="lazy"
            decoding="async"
            class="block w-full"
          />
        </div>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {pasos.map((p) => (
          <div class="rounded-2xl border border-hairline bg-white p-6 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
            <span class="text-4xl font-bold text-terracota/20">{p.n}</span>
            <h3 class="mt-3 text-lg text-ink">{p.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{p.d}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="#registro" class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-terracota px-7 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-terracota-light">
          Quiero mi primera hora gratis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ SEGURIDAD (comprimida) ════════════════════ -->
  <section class="bg-white py-12 sm:py-16">
    <Container>
      <div class="mx-auto max-w-2xl rounded-2xl border border-hairline bg-[#f8f9fa] p-6 text-center sm:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">Seguridad</p>
        <h2 class="mt-3 text-xl font-semibold text-ink sm:text-2xl">Entrás tranquila, incluso de noche.</h2>
        <p class="mt-3 text-sm leading-relaxed text-ink-soft">El edificio cuida quién entra, para que vos solo te ocupes de tu sesión.</p>
        <ul class="mt-5 flex flex-wrap justify-center gap-2">
          {seguridadPills.map((s) => (
            <li class="rounded-full border border-hairline bg-white px-3 py-1.5 text-xs font-medium text-ink-soft">{s}</li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ TESTIMONIOS (prueba social) ════════════════════ -->
  <section class="bg-ink py-16 text-white sm:py-24">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota-light">Nuestros primeros profesionales</p>
        <h2 class="text-3xl sm:text-4xl">Nos eligieron antes de abrir.</h2>
        <p class="mt-5 text-lg leading-relaxed text-white/70 text-pretty">Conocieron el espacio, les gustó y ya aseguraron sus horarios para la apertura. Que confíen antes de que abramos las puertas, para nosotros es un honor.</p>
      </div>
      <div class="mx-auto mt-12 grid max-w-4xl gap-4 sm:grid-cols-2">
        {testimonios.map((t) => (
          <figure class="flex h-full flex-col rounded-2xl border border-white/10 bg-white/[0.04] p-6 sm:p-7">
            <span class="mb-4 inline-flex w-fit items-center gap-1.5 rounded-full bg-terracota/20 px-3 py-1 text-[11px] font-medium text-terracota-light">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
