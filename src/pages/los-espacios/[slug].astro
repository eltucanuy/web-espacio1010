---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import EspacioCard from '../../components/EspacioCard.astro';
import { ESPACIOS, SITE } from '../../lib/site';
import { breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  return ESPACIOS.map((espacio) => ({
    params: { slug: espacio.id },
    props: { espacio },
  }));
}

const { espacio } = Astro.props;
const otros = ESPACIOS.filter((e) => e.id !== espacio.id).slice(0, 3);

const schemaBreadcrumb = breadcrumbSchema([
  { name: 'Inicio', url: '/' },
  { name: 'Los espacios', url: '/los-espacios' },
  { name: espacio.nombre, url: `/los-espacios/${espacio.id}` },
]);

// Schema.org Product para que Google entienda cada espacio como una "oferta".
const schemaProduct = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${espacio.nombre} — Espacio 1010`,
  description: espacio.resumen,
  brand: { '@type': 'Brand', name: 'Espacio 1010' },
  category: 'Alquiler de consultorio por hora',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: `${SITE.url}/los-espacios/${espacio.id}`,
    priceCurrency: 'UYU',
    // TBD — actualizar cuando Rafa confirme precios reales.
    price: '0',
    priceValidUntil: '2026-12-31',
  },
};

const amuebladoLabel = {
  completo: 'Amueblado completo',
  versatil: 'Versátil — vos configurás',
  mixto: 'Mixto — base + extras móviles',
}[espacio.amueblado];
---

<BaseLayout
  title={espacio.nombre}
  description={`${espacio.nombre} en Espacio 1010 — ${espacio.resumen} Capacidad: ${espacio.capacidad}. Reservá por hora online, 24/7, en Gaboto 1010, Cordón.`}
  ogSlug={`espacio-${espacio.id}`}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  </Fragment>

  <!-- Hero del espacio -->
  <section class="pt-12 pb-12 sm:pt-16 sm:pb-16">
    <Container size="wide">
      <nav aria-label="Migas de pan" class="mb-8 text-sm text-ink-muted">
        <a href="/" class="hover:text-terracota">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/los-espacios" class="hover:text-terracota">Los espacios</a>
        <span class="mx-2">/</span>
        <span class="text-ink">{espacio.nombre}</span>
      </nav>

      <div class="grid gap-12 md:grid-cols-12 md:items-center">
        <!-- Visual principal -->
        <div class="md:col-span-7">
          <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--radius-xl)] bg-gradient-to-br from-terracota-tint via-crema to-crema-warm shadow-[var(--shadow-md)]">
            <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true">
              <svg width="100%" height="100%">
                <defs>
                  <pattern id={`bg-${espacio.id}`} x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
                    <circle cx="24" cy="24" r="1.2" fill="#1a1518" />
                  </pattern>
                </defs>
                <rect width="100%" height="100%" fill={`url(#bg-${espacio.id})`} />
              </svg>
            </div>

            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display text-[10rem] leading-none text-terracota/25 select-none">
                {espacio.metros}
                <span class="text-3xl align-top">m²</span>
              </span>
            </div>

            <div class="absolute left-6 top-6 flex flex-col gap-2">
              {espacio.destacado && (
                <span class="inline-flex w-fit items-center rounded-full bg-ink px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-crema">
                  Destacado
                </span>
              )}
              <span class="inline-flex w-fit items-center rounded-full bg-crema/95 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-ink-soft">
                {amuebladoLabel}
              </span>
            </div>
          </div>
        </div>

        <!-- Info -->
        <div class="md:col-span-5">
          <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
            {amuebladoLabel}
          </p>
          <h1 class="text-balance">{espacio.nombre}</h1>
          <p class="mt-5 text-lg leading-relaxed text-ink-soft text-pretty">
            {espacio.resumen}
          </p>

          <dl class="mt-8 grid grid-cols-2 gap-6 border-y border-hairline py-6">
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-muted">
                Capacidad
              </dt>
              <dd class="mt-1.5 font-display text-xl text-ink">{espacio.capacidad}</dd>
            </div>
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-muted">
                Superficie
              </dt>
              <dd class="mt-1.5 font-display text-xl text-ink">{espacio.metros} m²</dd>
            </div>
          </dl>

          <div class="mt-8">
            <h3 class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink-muted">
              Ideal para
            </h3>
            <ul class="mt-3 flex flex-wrap gap-2">
              {espacio.ideal.map((i) => (
                <li class="rounded-full border border-terracota/20 bg-terracota-tint/60 px-3 py-1 text-xs font-medium text-terracota-dark">
                  {i}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <Button href={SITE.agendaUrl} variant="primary" size="lg">
              Reservar este espacio
            </Button>
            <Button href="/los-espacios" variant="ghost" size="lg">
              Ver los otros
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Qué incluye -->
  <section class="py-24 bg-crema-warm/30">
    <Container>
      <h2 class="font-display text-3xl text-ink">Qué viene incluido</h2>
      <p class="mt-3 max-w-xl text-ink-soft">
        Cada reserva en {espacio.nombre} incluye sin costo extra los siguientes
        servicios y comodidades del edificio.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { titulo: 'Wifi de fibra', desc: 'Conexión estable en todo el edificio.' },
          { titulo: 'A/C frío y calor', desc: 'Climatización individual por espacio.' },
          { titulo: 'Sala de espera', desc: 'Cómoda y privada para tus pacientes.' },
          { titulo: 'Cocina común', desc: 'Café, té y agua disponibles.' },
          { titulo: 'Música ambiente', desc: 'Suma privacidad acústica entre espacios.' },
          { titulo: 'Acceso 24/7', desc: 'Con tu código personal — sin coordinar.' },
        ].map((item) => (
          <div class="rounded-2xl border border-hairline bg-crema p-6">
            <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-full bg-terracota-tint text-terracota">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="font-display text-xl text-ink">{item.titulo}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{item.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Otros espacios -->
  <section class="py-24">
    <Container size="wide">
      <h2 class="font-display text-3xl text-ink">Otros espacios que podrían servirte</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {otros.map((e) => <EspacioCard espacio={e} />)}
      </div>
    </Container>
  </section>
</BaseLayout>
