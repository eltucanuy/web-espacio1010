---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import { ESPACIOS, SITE, ADDRESS } from '../../lib/site';
import type { Espacio } from '../../lib/site';

// Agrupamos por tipo para que el grid cuente una historia, no sólo enumere.
const consultas = ESPACIOS.filter((e) => e.id.startsWith('consulta'));
const estudios = ESPACIOS.filter((e) => e.id.startsWith('estudio'));
const salones = ESPACIOS.filter((e) => e.id.startsWith('salon'));
const subsuelo = ESPACIOS.find((e) => e.id === 'sala-subsuelo');

const PRECIO_HORA = 350;
const PRECIO_ARCOS = 700;

// Precio por hora real: $350 todos; $700 la Sala Arcos (subsuelo).
const precioDe = (e: Espacio) => (e.id === 'sala-subsuelo' ? PRECIO_ARCOS : PRECIO_HORA);

// Tratamiento sin fotos: cada espacio recibe un ícono según su tipo.
const iconPaths: Record<string, string> = {
  estudio: '<path d="M3 7h18M5 7v13M19 7v13M4 12h7"/><rect x="13" y="11" width="7" height="5" rx="1"/>',
  consulta: '<path d="M4 11V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/><path d="M2 13a2 2 0 0 1 4 0v3h12v-3a2 2 0 0 1 4 0v5H2z"/>',
  salon: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 20a6 6 0 0 1 12 0M15 20a5 5 0 0 1 6-3.5"/>',
  sala: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 20a6 6 0 0 1 12 0M15 20a5 5 0 0 1 6-3.5"/>',
};
const iconDe = (e: Espacio) => iconPaths[e.id.split('-')[0]] ?? iconPaths.consulta;

const amuebladoLabel: Record<string, string> = {
  completo: 'Amueblado',
  versatil: 'Versátil',
  mixto: 'Mixto',
};
---

<BaseLayout
  title="Los 12 espacios"
  description="Conocé los 12 espacios de Espacio 1010: consultas íntimas amobladas, estudios premium, salones versátiles y la Sala Arcos para hasta 30 personas. Todo entre Palermo y Parque Rodó, Montevideo."
  ogSlug="los-espacios"
>
  <!-- ════════════════════ HEADER ════════════════════ -->
  <section class="bg-white pt-16 pb-12 sm:pt-24 sm:pb-16">
    <Container>
      <nav aria-label="Migas de pan" class="mb-8 text-sm text-ink-muted">
        <a href="/" class="hover:text-terracota">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-ink">Los espacios</span>
      </nav>

      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Los espacios
      </p>
      <h1 class="text-balance text-ink">
        12 ambientes, <span class="text-terracota">una sola filosofía</span>.
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        Desde consultas íntimas para sesiones individuales hasta la Sala Arcos de
        60 m² para grupos. Cada uno fue pensado para una forma distinta de
        trabajar — y todos comparten el mismo estándar de detalle, entre Palermo
        y {ADDRESS.neighborhood}.
      </p>

      <!-- Leyenda de tipos de amueblado -->
      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-4 border-t border-hairline pt-6 text-sm text-ink-soft">
        <span class="inline-flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-terracota"></span>
          <strong class="font-semibold text-ink">Amueblado</strong> — sillón, escritorio, sillas
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-ink-soft"></span>
          <strong class="font-semibold text-ink">Mixto</strong> — base + materiales móviles
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full border border-hairline bg-[#f8f9fa]"></span>
          <strong class="font-semibold text-ink">Versátil</strong> — vos configurás
        </span>
      </div>
    </Container>
  </section>

  <!-- ════════════════════ SALA ARCOS (destacada) ════════════════════ -->
  {subsuelo && (
    <section class="bg-[#f8f9fa] py-12 sm:py-16">
      <Container>
        <p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">La gran sala</p>
        <div class="grid gap-6 lg:grid-cols-12">
          <a
            href={`/los-espacios/${subsuelo.id}`}
            class="group flex flex-col rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)] lg:col-span-5"
          >
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconDe(subsuelo)} />
            </span>
            <h2 class="mt-5 text-2xl text-ink">{subsuelo.nombre}</h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{subsuelo.resumen}</p>
            <div class="mt-6 flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
              <span>{subsuelo.capacidad} · {subsuelo.metros} m²</span>
              <span class="text-sm font-semibold text-terracota">${precioDe(subsuelo)} <span class="font-normal text-ink-muted">/ h</span></span>
            </div>
          </a>

          <div class="flex flex-col justify-center rounded-2xl border border-hairline bg-white p-8 sm:p-10 lg:col-span-7">
            <h3 class="text-2xl text-ink text-balance">Para cuando 30 personas se juntan a aprender, meditar o sanar.</h3>
            <p class="mt-4 text-base leading-relaxed text-ink-soft text-pretty">
              Sin columnas, mobiliario versátil, acústica trabajada. Ideal para
              talleres de fin de semana, formaciones, prácticas grupales o
              presentaciones. Reservala por bloques o por día completo, a ${PRECIO_ARCOS} la hora.
            </p>
            <div class="mt-6">
              <Button href={`/los-espacios/${subsuelo.id}`} variant="outline" size="md">
                Ver la Sala Arcos
              </Button>
            </div>
          </div>
        </div>
      </Container>
    </section>
  )}

  <!-- ════════════════════ ESTUDIOS ════════════════════ -->
  <section class="bg-white py-12 sm:py-16">
    <Container size="wide">
      <h2 class="mb-2 text-2xl text-ink sm:text-3xl">Estudios premium</h2>
      <p class="mb-8 text-ink-soft">Los más amplios y luminosos, para sesiones largas.</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {estudios.map((e) => (
          <a
            href={`/los-espacios/${e.id}`}
            class="group flex flex-col rounded-2xl border border-hairline bg-[#f8f9fa] p-6 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]"
          >
            <div class="flex items-start justify-between">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconDe(e)} />
              </span>
              <span class="rounded-full bg-white px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-soft">{amuebladoLabel[e.amueblado]}</span>
            </div>
            <h3 class="mt-5 text-lg text-ink">{e.nombre}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{e.resumen}</p>
            <div class="mt-auto flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
              <span>{e.capacidad} · {e.metros} m²</span>
              <span class="text-sm font-semibold text-terracota">${precioDe(e)} <span class="font-normal text-ink-muted">/ h</span></span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ════════════════════ CONSULTAS ════════════════════ -->
  <section class="bg-[#f8f9fa] py-12 sm:py-16">
    <Container size="wide">
      <h2 class="mb-2 text-2xl text-ink sm:text-3xl">Consultas individuales</h2>
      <p class="mb-8 text-ink-soft">Íntimas y silenciosas, pensadas para la sesión uno a uno.</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {consultas.map((e) => (
          <a
            href={`/los-espacios/${e.id}`}
            class="group flex flex-col rounded-2xl border border-hairline bg-white p-6 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]"
          >
            <div class="flex items-start justify-between">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconDe(e)} />
              </span>
              <span class="rounded-full bg-[#f8f9fa] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-soft">{amuebladoLabel[e.amueblado]}</span>
            </div>
            <h3 class="mt-5 text-lg text-ink">{e.nombre}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{e.resumen}</p>
            <div class="mt-auto flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
              <span>{e.capacidad} · {e.metros} m²</span>
              <span class="text-sm font-semibold text-terracota">${precioDe(e)} <span class="font-normal text-ink-muted">/ h</span></span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ════════════════════ SALONES GRUPALES ════════════════════ -->
  <section class="bg-white py-12 sm:py-16">
    <Container size="wide">
      <h2 class="mb-2 text-2xl text-ink sm:text-3xl">Salones grupales</h2>
      <p class="mb-8 text-ink-soft">Versátiles, para grupos chicos y talleres de medio día.</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {salones.map((e) => (
          <a
            href={`/los-espacios/${e.id}`}
            class="group flex flex-col rounded-2xl border border-hairline bg-[#f8f9fa] p-6 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]"
          >
            <div class="flex items-start justify-between">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-terracota-tint text-terracota">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconDe(e)} />
              </span>
              <span class="rounded-full bg-white px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-soft">{amuebladoLabel[e.amueblado]}</span>
            </div>
            <h3 class="mt-5 text-lg text-ink">{e.nombre}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{e.resumen}</p>
            <div class="mt-auto flex items-center justify-between border-t border-hairline pt-4 text-xs text-ink-muted">
              <span>{e.capacidad} · {e.metros} m²</span>
              <span class="text-sm font-semibold text-terracota">${precioDe(e)} <span class="font-normal text-ink-muted">/ h</span></span>
            </div>
          </a>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-ink-muted">Fotos reales de cada espacio, muy pronto.</p>
    </Container>
  </section>

  <!-- ════════════════════ CTA ════════════════════ -->
  <section class="bg-[#f8f9fa] py-20 sm:py-28">
    <Container>
      <div class="rounded-[var(--radius-xl)] border border-hairline bg-white p-12 text-center shadow-[var(--shadow-md)] sm:p-16">
        <h2 class="text-balance text-ink">¿Listo para reservar?</h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-ink-soft text-pretty">
          Creá tu cuenta gratis y entrá a ver la disponibilidad real de los 12
          espacios para los próximos días.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href={SITE.agendaUrl} variant="primary" size="lg">
            Crear cuenta y reservar
          </Button>
          <Button href="/contacto" variant="ghost" size="lg">
            Tengo una consulta
          </Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
