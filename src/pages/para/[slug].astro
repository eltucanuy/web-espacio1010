---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import EspacioCard from '../../components/EspacioCard.astro';
import { NICHOS_CONTENT } from '../../lib/nichos';
import { ESPACIOS, SITE, CONTACT } from '../../lib/site';
import { breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  return Object.values(NICHOS_CONTENT).map((nicho) => ({
    params: { slug: nicho.slug },
    props: { nicho },
  }));
}

const { nicho } = Astro.props;

// La Sala Arcos no se reserva por la app: en talleres-grupos el CTA primario es WhatsApp.
const esTalleres = nicho.slug === 'talleres-grupos';
// meditacion-yoga también recomienda la Sala Arcos: el subtexto del hero muestra ambos precios.
const esYoga = nicho.slug === 'meditacion-yoga';

// Buscamos los espacios recomendados en el array global.
const espaciosDelNicho = nicho.espaciosRecomendados
  .map((id) => ESPACIOS.find((e) => e.id === id))
  .filter((e): e is NonNullable<typeof e> => Boolean(e))
  .slice(0, 4);

// Schema.org Service — qué servicio ofrecemos para este nicho.
const schemaService = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: nicho.label,
  provider: { '@type': 'LocalBusiness', '@id': `${SITE.url}/#business`, name: 'Espacio 1010', url: SITE.url },
  areaServed: { '@type': 'City', name: 'Montevideo' },
  description: nicho.intro,
  url: `${SITE.url}/para/${nicho.slug}`,
};

const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: nicho.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schemaBreadcrumb = breadcrumbSchema([
  { name: 'Inicio', url: '/' },
  { name: nicho.label, url: `/para/${nicho.slug}` },
]);
---

<BaseLayout title={nicho.titleSeo} description={nicho.meta} ogSlug={`nicho-${nicho.slug}`}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaService)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  </Fragment>

  <!-- Hero -->
  <section class="pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        {esTalleres ? 'Salas para grupos y talleres' : 'Tu primera hora gratis'}
      </p>
      <h1 class="text-balance">{nicho.label}</h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        {nicho.intro}
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        {
          esTalleres ? (
            <>
              <Button href={CONTACT.whatsappLink(nicho.whatsappIntro)} variant="primary" size="lg" target="_blank">
                Consultar por la Sala Arcos
              </Button>
              <Button href="#registro" variant="ghost" size="lg">
                Quiero mi primera hora gratis
              </Button>
            </>
          ) : (
            <>
              <Button href="#registro" variant="primary" size="lg">
                Quiero mi primera hora gratis
              </Button>
              <Button href="/los-espacios" variant="ghost" size="lg">
                Ver los espacios
              </Button>
            </>
          )
        }
      </div>
      <p class="mt-4 text-sm text-ink-soft">
        {
          esTalleres
            ? 'Sala Arcos: $700 la hora · espacios multiuso para grupos chicos: $350 — y tu primera hora es gratis al registrarte.'
            : esYoga
              ? 'Espacios multiuso: $350 la hora, todo incluido · Sala Arcos para grupos grandes: $700 — y tu primera hora es gratis al registrarte.'
              : '$350 la hora, todo incluido · sin costos fijos ni compromiso — y tu primera hora es gratis.'
        }
      </p>
    </Container>
  </section>

  <!-- Pain points + solución -->
  <section class="py-20 bg-[#f8f9fa]">
    <Container>
      <div class="grid gap-12 md:grid-cols-2 md:items-start">
        <div>
          <h2 class="font-display text-3xl text-ink">Lo que probablemente te suene.</h2>
          <ul class="mt-8 space-y-4">
            {
              nicho.painPoints.map((p) => (
                <li class="flex items-start gap-3 text-base leading-relaxed text-ink-soft">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-terracota"></span>
                  {p}
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="font-display text-3xl text-ink">Cómo lo resolvemos.</h2>
          <p class="mt-8 text-base leading-relaxed text-ink-soft text-pretty">{nicho.solucion}</p>
          <div class="mt-8">
            <Button href="/como-funciona" variant="outline" size="md">
              Ver cómo funciona
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Fotos reales del lugar -->
  <section class="py-16">
    <Container>
      <div class="grid gap-4 sm:grid-cols-2">
        {nicho.fotos.map((f) => (
          <figure class="group overflow-hidden rounded-[var(--radius-xl)] border border-hairline shadow-[var(--shadow-md)]">
            <div class="relative aspect-[3/2] overflow-hidden">
              <img src={f.src} alt={f.alt} loading="lazy" decoding="async"
                class="h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-out-soft)] group-hover:scale-105" />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent p-4 pt-12">
                <p class="text-sm font-medium text-white">{f.cap}</p>
              </div>
            </div>
          </figure>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-ink-muted">
        Fotos reales del edificio. Abajo, cada espacio con las suyas.
      </p>
    </Container>
  </section>

  <!-- Espacios recomendados -->
  <section class="py-24">
    <Container size="wide">
      <h2 class="font-display text-3xl text-ink">Espacios pensados para tu práctica.</h2>
      <p class="mt-3 max-w-xl text-ink-soft">
        Los que mejor se ajustan a tu forma de trabajar.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {espaciosDelNicho.map((e) => <EspacioCard espacio={e} />)}
      </div>
    </Container>
  </section>

  <!-- Testimonial (solo nichos con testimonio real aprobado) -->
  {
    nicho.testimonial && (
      <section class="py-20 bg-ink text-crema">
        <Container size="narrow">
          <span class="mb-5 inline-flex w-fit items-center gap-1.5 rounded-full bg-terracota/20 px-3 py-1 text-[11px] font-medium text-terracota-light">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5" /></svg>
            Ya reservó para la apertura
          </span>
          <svg class="mb-6 text-terracota-light" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
            <path d="M7 7c-2 0-3.5 1.5-3.5 3.5S5 14 7 14c0 2-1.5 3.5-3.5 3.5v2C7 19.5 9 17 9 13V8c0-.5-.5-1-1-1zm9 0c-2 0-3.5 1.5-3.5 3.5s1.5 3.5 3.5 3.5c0 2-1.5 3.5-3.5 3.5v2c3.5 0 5.5-2.5 5.5-6.5V8c0-.5-.5-1-1-1z" />
          </svg>
          <blockquote class="font-display text-3xl leading-tight text-crema sm:text-4xl">
            "{nicho.testimonial.texto}"
          </blockquote>
          <footer class="mt-6 text-sm text-crema/70">
            — {nicho.testimonial.autor}, {nicho.testimonial.rol}
          </footer>
        </Container>
      </section>
    )
  }

  <!-- Variantes de búsqueda — long-tail SEO sin diluir URLs -->
  <section class="py-16 bg-[#f8f9fa]">
    <Container size="narrow">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        También conocido como
      </p>
      <h2 class="mt-3 font-display text-2xl text-ink">
        Si llegaste buscando alguna de estas, estás en el lugar correcto.
      </h2>
      <ul class="mt-6 flex flex-wrap gap-2">
        {
          nicho.variantesBusqueda.map((v) => (
            <li class="inline-flex items-center rounded-full border border-hairline bg-white px-4 py-2 text-sm text-ink-soft">
              {v}
            </li>
          ))
        }
      </ul>
    </Container>
  </section>

  <!-- FAQ -->
  <section class="py-24">
    <Container size="narrow">
      <h2 class="font-display text-3xl text-ink">Preguntas frecuentes en tu profesión.</h2>
      <div class="mt-10 space-y-3">
        {
          nicho.faq.map((item) => (
            <details class="group rounded-2xl border border-hairline bg-white p-6 transition-colors duration-300 hover:border-terracota/30">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-medium text-ink">
                {item.q}
                <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-terracota-tint text-terracota transition-transform duration-300 group-open:rotate-45">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 5v14M5 12h14" stroke-linecap="round" />
                  </svg>
                </span>
              </summary>
              <p class="mt-4 text-base leading-relaxed text-ink-soft">{item.a}</p>
            </details>
          ))
        }
      </div>
    </Container>
  </section>

  <!-- CTA final -->
  <section class="py-24">
    <Container>
      <div class="rounded-[var(--radius-xl)] bg-gradient-to-br from-terracota via-terracota-dark to-ink p-12 text-center text-crema sm:p-20">
        <h2 class="text-balance text-crema">{esTalleres ? '¿Armamos tu taller?' : 'Tu primera hora, gratis.'}</h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-crema/85">
          {
            esTalleres
              ? 'Contanos fecha, duración y cuántas personas vienen, y lo coordinamos por WhatsApp. Y si también atendés individual, registrate: tu primera hora en los consultorios es gratis.'
              : 'Registrate gratis, sin tarjeta y sin compromiso. Te guardamos tu primera hora para usarla cuando quieras, en el espacio que elijas.'
          }
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          {
            esTalleres ? (
              <>
                <Button
                  href={CONTACT.whatsappLink(nicho.whatsappIntro)}
                  variant="light"
                  size="lg"
                  target="_blank"
                >
                  Consultar por la Sala Arcos
                </Button>
                <Button href="#registro" variant="ghost-light" size="lg">
                  Quiero mi primera hora gratis
                </Button>
              </>
            ) : (
              <>
                <Button href="#registro" variant="light" size="lg">
                  Quiero mi primera hora gratis
                </Button>
                <Button
                  href={CONTACT.whatsappLink(nicho.whatsappIntro)}
                  variant="ghost"
                  size="lg"
                  class="text-crema hover:bg-white/10"
                  target="_blank"
                >
                  Hablar por WhatsApp
                </Button>
              </>
            )
          }
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
