---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { CONTACT } from '../lib/site';

// Precios reales — fuente de verdad: docs/VERDAD_APP_2026_06_10.md (la app manda).
// Consultorios y salas: $350/h. Sala Arcos (subsuelo): $700/h.
// Dos formas de reservar: hora suelta o fija semanal. Descuentos por volumen:
// 20 h o más al mes → 10% · 40 h o más → 20% (automáticos, sobre el total del mes).
const PRECIO_HORA = 350;
const PRECIO_ARCOS = 700;

const planes = [
  {
    nombre: 'Hora suelta',
    bajada: 'Reservás cuando la necesitás.',
    precio: `$${PRECIO_HORA}`,
    unidad: 'por hora',
    destacado: false,
    incluye: [
      'Cualquier espacio disponible',
      'Desde 1 hora, sin compromiso ni contrato',
      'Cancelás gratis hasta 24 h antes (50% hasta 1 h antes)',
      'Reservás hasta con 150 días de anticipación',
    ],
    cta: { label: 'Quiero mi primera hora gratis', variant: 'outline' as const },
  },
  {
    nombre: 'Fija semanal',
    bajada: 'Tu día, tu hora y tu espacio, todas las semanas.',
    precio: `$${PRECIO_HORA}`,
    unidad: 'por hora',
    destacado: true,
    incluye: [
      'Mismo espacio, día y hora cada semana',
      'La cortás cuando quieras, sin trámite ni penalización',
      'Cancelaciones gratis todos los meses (hasta el 20% de tus horas fijas)',
      'Suma para tu descuento por volumen',
    ],
    cta: { label: 'Quiero empezar con mi hora gratis', variant: 'primary' as const },
  },
];

const schemaPrecios = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Alquiler de consultorios y salas por hora',
  provider: { '@type': 'LocalBusiness', name: 'Espacio 1010' },
  areaServed: 'Montevideo, Uruguay',
  offers: [
    {
      '@type': 'Offer',
      name: 'Consultorios y salas',
      price: '350',
      priceCurrency: 'UYU',
      description:
        'Precio por hora, único para todos los consultorios y salas. Descuentos automáticos: 10% desde 20 h al mes, 20% desde 40 h.',
    },
    {
      '@type': 'Offer',
      name: 'Sala Arcos',
      price: '700',
      priceCurrency: 'UYU',
      description:
        'Sala del subsuelo de 40 m² para hasta 25 personas sentadas, por hora. Se coordina por WhatsApp.',
    },
  ],
};
---

<BaseLayout
  title="Precios: consultorio por hora a $350"
  description="Consultorio por hora a $350 en Montevideo, precio único y sin sorpresas. Descuentos de hasta 20%, pago a mes vencido sin tarjeta. Tu primera hora es gratis."
  ogSlug="precios"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaPrecios)} />
  </Fragment>

  <!-- Hero -->
  <section class="pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Precios
      </p>
      <h1 class="text-balance">
        Precios sin letra chica.
        <span class="text-terracota">Sin sorpresas.</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        Un solo precio: $350 la hora, en todos los consultorios y salas (solo
        la Sala Arcos, para grupos grandes, sale $700). Reservás suelto o
        con horario fijo semanal, y cuanto más usás en el mes, menos pagás.
        Sin matrícula, sin mínimos, sin costos fijos.
      </p>
    </Container>
  </section>

  <!-- Banner pre-lanzamiento: primera hora gratis -->
  <section class="pb-16">
    <Container>
      <div class="rounded-[var(--radius-lg)] border-2 border-terracota bg-terracota-tint/40 p-6 sm:flex sm:items-center sm:justify-between sm:gap-8 sm:p-8">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">
            Pre-lanzamiento · abrimos en junio
          </p>
          <h2 class="mt-2 font-display text-2xl text-ink sm:text-3xl">
            Tu primera hora, gratis.
          </h2>
          <p class="mt-2 text-base text-ink-soft">
            Pre-registrate hoy y te guardamos una hora sin cargo para usarla
            cuando quieras durante 2026, en el espacio que elijas.
          </p>
        </div>
        <div class="mt-5 sm:mt-0 sm:flex-shrink-0">
          <Button href="/#registro" variant="primary" size="md">
            Quiero mi primera hora gratis
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Cards de modalidades -->
  <section class="pb-24">
    <Container size="wide">
      <div class="mx-auto grid max-w-3xl gap-6 sm:grid-cols-2">
        {
          planes.map((p) => (
            <article
              class={`relative flex flex-col rounded-[var(--radius-lg)] p-8 transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 ${
                p.destacado
                  ? 'border-2 border-terracota bg-white shadow-[var(--shadow-md)]'
                  : 'border border-hairline bg-white hover:border-terracota/30 hover:shadow-[var(--shadow-md)]'
              }`}
            >
              {p.destacado && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-terracota px-4 py-1.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-crema">
                  Para tu consulta semanal
                </span>
              )}

              <h2 class="font-display text-2xl text-ink">{p.nombre}</h2>
              <p class="mt-2 text-sm text-ink-soft">{p.bajada}</p>

              <div class="mt-8 flex items-baseline gap-2 border-t border-hairline pt-6">
                <span class="font-display text-5xl text-ink">{p.precio}</span>
                <span class="text-sm text-ink-muted">{p.unidad}</span>
              </div>

              <ul class="mt-8 space-y-3 flex-1">
                {p.incluye.map((i) => (
                  <li class="flex items-start gap-3 text-sm text-ink-soft">
                    <svg class="mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                      <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {i}
                  </li>
                ))}
              </ul>

              <div class="mt-8">
                <Button href="/#registro" variant={p.cta.variant} size="md" class="w-full">
                  {p.cta.label}
                </Button>
              </div>
            </article>
          ))
        }
      </div>

      <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-ink-soft">
        Cancelación simple: gratis avisando con más de 24 h; hasta 1 h antes
        pagás solo la mitad; con menos de 1 h ya no se puede cancelar.
        En las fijas, las cancelaciones gratis tienen un
        tope del 20% de tus horas fijas del mes.
        <a href="/preguntas-frecuentes" class="font-medium text-terracota underline-offset-2 hover:underline">Más detalles en las preguntas frecuentes →</a>
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-center text-sm text-ink-soft">
        Tu primera hora es gratis:
        <a href="/#registro" class="font-medium text-terracota underline-offset-2 hover:underline">pre-registrate</a>
        y queda guardada a tu nombre para usarla durante 2026.
      </p>

      <!-- Sala Arcos -->
      <div class="mt-10 overflow-hidden rounded-2xl border border-hairline bg-[#f8f9fa] sm:flex sm:items-stretch">
        <img
          src="/fotos/lugar-sala-subsuelo.webp"
          alt="Sala Arcos, la gran sala del subsuelo con paredes de piedra y arcos"
          class="h-56 w-full object-cover sm:h-auto sm:w-2/5"
          loading="lazy"
          decoding="async"
        />
        <div class="flex flex-col justify-center gap-4 p-6 sm:p-8">
          <p class="text-base text-ink">
            <span class="font-display text-2xl text-terracota">${PRECIO_ARCOS}/h</span>
            <span class="ml-2 font-medium">Sala Arcos</span>
            <span class="text-ink-soft"> — la gran sala del subsuelo: 40 m² para hasta 25 personas sentadas, con proyector, parlante, kitchenette y baño propio.</span>
          </p>
          <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
            <a
              href={CONTACT.whatsappLink('Hola! Quiero consultar por la Sala Arcos.')}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-base font-medium text-terracota hover:underline"
            >
              Consultala por WhatsApp
            </a>
            <a
              href="/los-espacios/sala-arcos"
              class="text-sm font-medium text-ink-soft underline-offset-2 hover:text-terracota hover:underline"
            >
              Conocé la Sala Arcos →
            </a>
          </div>
        </div>
      </div>

      <p class="mt-6 text-center text-sm text-ink-muted">
        Precios en pesos uruguayos. Consultorios y salas: ${PRECIO_HORA} la hora, precio único.
      </p>
    </Container>
  </section>

  <!-- Descuentos por volumen -->
  <section class="py-20 bg-[#f8f9fa]">
    <Container size="narrow">
      <h2 class="font-display text-4xl text-ink">Cuanto más reservás, menos pagás.</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-soft">
        Los descuentos se aplican automáticamente al pasar cierto volumen
        mensual. Sin trámites ni promociones que tenés que pedir.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">Menos de 20 h al mes</p>
          <h3 class="mt-3 font-display text-xl text-ink">$350 la hora</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            La tarifa estándar, sin mínimos ni costos fijos.
          </p>
        </div>
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">20 h o más al mes</p>
          <h3 class="mt-3 font-display text-xl text-ink">10% de descuento</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Queda en $315 la hora. El descuento se aplica automáticamente sobre el total del mes.
          </p>
        </div>
        <div class="rounded-2xl border-2 border-terracota bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">40 h o más al mes</p>
          <h3 class="mt-3 font-display text-xl text-ink">20% de descuento</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Queda en $280 la hora. La mejor tarifa del esquema.
          </p>
        </div>
      </div>

      <p class="mt-6 text-sm text-ink-muted">
        El descuento se calcula solo, sobre todas tus horas del mes, y lo ves en
        tu liquidación el día 1. No hay que pedirlo ni hacer ningún trámite.
      </p>
    </Container>
  </section>

  <!-- Cómo se paga -->
  <section class="py-20">
    <Container size="narrow">
      <h2 class="font-display text-4xl text-ink">¿Y cómo se paga? Después de usar.</h2>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <h3 class="font-display text-xl text-ink">A mes vencido</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Usás el espacio todo el mes y recién el día 1 recibís el detalle de
            tus horas, con los descuentos ya aplicados. Tenés 10 días para pagarlo.
          </p>
        </div>
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <h3 class="font-display text-xl text-ink">Sin tarjeta</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            No te pedimos tarjeta nunca: ni para registrarte, ni para reservar.
            Nada de cobros automáticos ni adelantos.
          </p>
        </div>
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <h3 class="font-display text-xl text-ink">Como te quede cómodo</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Pagás por transferencia bancaria o depósito en Abitab o RedPagos.
            Si lo necesitás, podés ir pagando en partes.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Qué incluye el precio -->
  <section class="py-20 bg-[#f8f9fa]">
    <Container size="narrow">
      <h2 class="font-display text-3xl text-ink">Qué incluye siempre el precio.</h2>
      <p class="mt-3 text-ink-soft">
        Nada de cargos sorpresa. Estos servicios vienen incluidos en cualquier modalidad.
      </p>

      <ul class="mt-10 grid gap-4 sm:grid-cols-2">
        {[
          'Espacios amoblados y climatizados',
          'Dos salas de espera para quienes atendés, una por piso',
          'Cocina y sala de estar para profesionales, con café, té y agua sin cargo',
          'Acceso 24/7 con código personal',
          'Videoportero y cámaras en accesos y zonas comunes (nunca en los espacios de atención)',
          'Wifi en todo el edificio',
        ].map((i) => (
          <li class="flex items-start gap-3 text-base text-ink">
            <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
              <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {i}
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- CTA final -->
  <section class="py-24">
    <Container>
      <div class="rounded-[var(--radius-xl)] bg-ink p-12 text-center text-crema sm:p-20">
        <h2 class="text-balance text-crema">
          Pre-registrarte es gratis.
          <span class="text-terracota">Reservar, cuando abramos.</span>
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-crema/80">
          Dejá tu nombre y WhatsApp, te guardamos tu primera hora gratis y te
          avisamos apenas abrimos las puertas. Sin tarjeta, sin compromiso.
        </p>
        <div class="mt-8">
          <Button href="/#registro" variant="primary" size="lg" class="bg-white text-terracota hover:bg-[#f8f9fa]">
            Quiero mi primera hora gratis
          </Button>
        </div>
        <p class="mt-5">
          <a
            href={CONTACT.whatsappLink('Hola! Tengo una consulta sobre los precios de Espacio 1010.')}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-crema/70 underline underline-offset-2 hover:text-crema"
          >
            o escribinos por WhatsApp
          </a>
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
