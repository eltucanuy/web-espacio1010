---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { SITE } from '../lib/site';

// Precios reales — fuente de verdad para el sitio institucional.
// Consultorios: $350/h. Sala Arcos (subsuelo): $700/h.
const PRECIO_HORA = 350;
const PRECIO_ARCOS = 700;

const planes = [
  {
    nombre: 'Hora suelta',
    bajada: 'Reservás cuando la necesitás.',
    precio: `$${PRECIO_HORA}`,
    unidad: 'por hora',
    destacado: false,
    incluye: [
      'Cualquier consultorio disponible',
      'Sin compromiso ni contrato',
      'Cancelás con 24 hs, no pagás',
      'Cowork gratis incluido',
    ],
    cta: { label: 'Reservar hora', variant: 'outline' as const },
  },
  {
    nombre: 'Pack de horas',
    bajada: 'Comprás un bloque y lo usás cuando quieras.',
    precio: `$${PRECIO_HORA}`,
    unidad: 'por hora · descuento por volumen',
    destacado: true,
    incluye: [
      'Mejor tarifa cuanto más reservás',
      'Las horas no se vencen mientras tengas cuenta',
      'Combinás distintos consultorios',
      'Prioridad sobre la hora suelta',
    ],
    cta: { label: 'Comprar pack', variant: 'primary' as const },
  },
  {
    nombre: 'Fija mensual',
    bajada: 'Día y espacio garantizados, todas las semanas.',
    precio: `$${PRECIO_HORA}`,
    unidad: 'por hora · tarifa fija',
    destacado: false,
    incluye: [
      'La mejor tarifa por volumen mensual',
      'Tu día y hora reservados sin trámite',
      'Cancelaciones flexibles dentro del tope mensual',
      'Bonificación si cancelás con tiempo',
    ],
    cta: { label: 'Reservar fija', variant: 'outline' as const },
  },
];

const schemaFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta alquilar consultorio por hora en Espacio 1010?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Los consultorios cuestan $350 por hora, precio único para todos. La Sala Arcos (subsuelo, hasta 30 personas) cuesta $700 por hora. Hay tres modalidades: hora suelta, pack de horas y serie fija mensual, con mejor tarifa cuanto más reservás por mes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Hay contrato anual?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Reservás por hora o por serie fija mes a mes. Cortás cuando quieras desde tu panel.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué incluye el precio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Acceso al espacio + wifi + climatización + sala de espera + sala de cowork + cocina común + acceso 24/7. Sin cargos extra.',
      },
    },
  ],
};
---

<BaseLayout
  title="Precios"
  description="Tarifas claras para alquilar consultorio por hora en Espacio 1010. Tres modalidades: hora suelta, pack de horas y serie fija mensual. Sin contratos anuales."
  ogSlug="precios"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  </Fragment>

  <!-- Hero -->
  <section class="pt-16 pb-16 sm:pt-24 sm:pb-20">
    <Container>
      <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.22em] text-terracota">
        Precios
      </p>
      <h1 class="text-balance">
        Sin letra chica.
        <span class="text-terracota">Sin sorpresas.</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft text-pretty">
        Tres formas de usar el espacio. Elegís la que mejor se adapta a cómo
        trabajás, no a cuánto te quieren cobrar. Y si cambia tu agenda,
        cambiás de plan sin penalización.
      </p>
    </Container>
  </section>

  <!-- Banner Tarifa Fundadores -->
  <section class="pb-16">
    <Container>
      <div class="rounded-[var(--radius-lg)] border-2 border-terracota bg-terracota-tint/40 p-6 sm:flex sm:items-center sm:justify-between sm:gap-8 sm:p-8">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">
            Apertura · cupo limitado
          </p>
          <h2 class="mt-2 font-display text-2xl text-ink sm:text-3xl">
            Tarifa Fundadores — las primeras 50 cuentas
          </h2>
          <p class="mt-2 text-base text-ink-soft">
            Tarifa congelada por 6 meses + primer mes de fija sin cargo. Quedan 41 cupos.
          </p>
        </div>
        <div class="mt-5 sm:mt-0 sm:flex-shrink-0">
          <Button href={SITE.agendaUrl} variant="primary" size="md">
            Reservar mi cupo
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Cards de planes -->
  <section class="pb-24">
    <Container size="wide">
      <div class="grid gap-6 lg:grid-cols-3">
        {
          planes.map((p) => (
            <article
              class={`relative flex flex-col rounded-[var(--radius-lg)] p-8 transition-all duration-500 ease-[var(--ease-out-soft)] hover:-translate-y-1 ${
                p.destacado
                  ? 'border-2 border-terracota bg-white shadow-[var(--shadow-md)]'
                  : 'border border-hairline bg-white hover:border-terracota/30 hover:shadow-[var(--shadow-md)]'
              }`}
            >
              {p.destacado && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-terracota px-4 py-1.5 text-[10px] font-semibold uppercase tracking-[0.16em] text-crema">
                  Más elegido
                </span>
              )}

              <h2 class="font-display text-2xl text-ink">{p.nombre}</h2>
              <p class="mt-2 text-sm text-ink-soft">{p.bajada}</p>

              <div class="mt-8 flex items-baseline gap-2 border-t border-hairline pt-6">
                <span class="font-display text-5xl text-ink">{p.precio}</span>
                <span class="text-sm text-ink-muted">{p.unidad}</span>
              </div>

              <ul class="mt-8 space-y-3 flex-1">
                {p.incluye.map((i) => (
                  <li class="flex items-start gap-3 text-sm text-ink-soft">
                    <svg class="mt-0.5 flex-shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
                      <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    {i}
                  </li>
                ))}
              </ul>

              <div class="mt-8">
                <Button href={SITE.agendaUrl} variant={p.cta.variant} size="md" class="w-full">
                  {p.cta.label}
                </Button>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-10 rounded-2xl border border-hairline bg-[#f8f9fa] p-6 text-center sm:flex sm:items-center sm:justify-center sm:gap-3 sm:text-left">
        <p class="text-base text-ink">
          <span class="font-display text-2xl text-terracota">${PRECIO_ARCOS}/h</span>
          <span class="ml-2 font-medium">Sala Arcos</span>
          <span class="text-ink-soft"> — la gran sala del subsuelo, hasta 30 personas, sin columnas.</span>
        </p>
      </div>

      <p class="mt-6 text-center text-sm text-ink-muted">
        Precios en pesos uruguayos. Todos los consultorios: ${PRECIO_HORA} la hora, precio único.
      </p>
    </Container>
  </section>

  <!-- Descuentos por volumen -->
  <section class="py-20 bg-[#f8f9fa]">
    <Container size="narrow">
      <h2 class="font-display text-4xl text-ink">Cuanto más reservás, menos pagás.</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-soft">
        Los descuentos se aplican automáticamente al pasar cierto volumen
        mensual. Sin trámites ni promociones que tenés que pedir.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">Empezando</p>
          <h3 class="mt-3 font-display text-xl text-ink">Pocas horas al mes</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Pagás la tarifa estándar de $350 la hora. Ideal para arrancar tu
            práctica sin asumir ningún costo fijo.
          </p>
        </div>
        <div class="rounded-2xl border border-hairline bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-terracota/30 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">Práctica estable</p>
          <h3 class="mt-3 font-display text-xl text-ink">Varias horas por semana</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            Al superar cierto volumen mensual, tu tarifa por hora baja
            automáticamente. Lo ves reflejado en tu liquidación.
          </p>
        </div>
        <div class="rounded-2xl border-2 border-terracota bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[var(--shadow-md)]">
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-terracota">Práctica intensiva</p>
          <h3 class="mt-3 font-display text-xl text-ink">Muchas horas o fija mensual</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-soft">
            La mejor tarifa del esquema. Cuantas más horas reservás por mes,
            menos pagás cada una. Sin trámites ni promociones que pedir.
          </p>
        </div>
      </div>

      <p class="mt-6 text-sm text-ink-muted">
        Los tramos exactos y el ahorro por hora los coordinás al crear tu cuenta — se calculan solos sobre tu uso real.
      </p>
    </Container>
  </section>

  <!-- Qué incluye el precio -->
  <section class="py-20">
    <Container size="narrow">
      <h2 class="font-display text-3xl text-ink">Qué incluye siempre el precio.</h2>
      <p class="mt-3 text-ink-soft">
        Nada de cargos sorpresa. Estos servicios vienen incluidos en cualquier modalidad.
      </p>

      <ul class="mt-10 grid gap-4 sm:grid-cols-2">
        {[
          'Wifi de fibra en todo el edificio',
          'Climatización individual por espacio',
          'Sala de espera para tus pacientes',
          'Cocina común con café, té y agua',
          'Sala de cowork mientras esperás',
          'Acceso 24/7 con código personal',
          'Música ambiente para privacidad',
          'Mantenimiento y limpieza diaria',
        ].map((i) => (
          <li class="flex items-start gap-3 text-base text-ink">
            <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9e4e42" stroke-width="2">
              <path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {i}
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- CTA final -->
  <section class="py-24">
    <Container>
      <div class="rounded-[var(--radius-xl)] bg-ink p-12 text-center text-crema sm:p-20">
        <h2 class="text-balance text-crema">
          Crear cuenta es gratis.
          <span class="text-terracota">Reservar después.</span>
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-crema/80">
          Mirá la agenda real antes de comprometerte. Si te convence, reservás.
          Si no, no hiciste nada.
        </p>
        <div class="mt-8">
          <Button href={SITE.agendaUrl} variant="primary" size="lg" class="bg-white text-terracota hover:bg-[#f8f9fa]">
            Empezar gratis
          </Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
